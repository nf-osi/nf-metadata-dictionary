{
  "$id": "https://repo-prod.prod.sagebase.org/repo/v1/schema/type/registered/org.synapse.nf-methylationarraytemplate",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "allOf": [
    {
      "if": {
        "properties": {
          "age": {
            "not": {
              "anyOf": [
                {
                  "const": "Unknown"
                }
              ]
            }
          }
        },
        "required": [
          "age"
        ]
      },
      "then": {
        "properties": {
          "ageUnit": {}
        },
        "required": [
          "ageUnit"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "species": {
            "const": "Homo sapiens"
          }
        },
        "required": [
          "species"
        ]
      },
      "then": {
        "properties": {
          "age": {
            "maximum": 89.99999
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "dataType": {}
        },
        "required": [
          "dataType"
        ]
      },
      "then": {
        "properties": {
          "dataSubtype": {}
        },
        "required": [
          "dataSubtype"
        ]
      }
    }
  ],
  "description": "Template for raw data files (idat) from DNA methylation arrays.",
  "properties": {
    "chipID": {
      "description": "User-specified identifier for the chip used to perform the methylation microarray.",
      "type": "string",
      "title": "chipID"
    },
    "chipPosition": {
      "description": "User-specified identifier for the specific position on the chip that the sample was loaded into to perform the methylation microarray.",
      "type": "string",
      "title": "chipPosition"
    },
    "plateName": {
      "description": "User-specified identifier of the plate used to prepare the sample for analysis.",
      "type": "string",
      "title": "plateName"
    },
    "plateWell": {
      "description": "User-specified identifier for the specific well of the plate used to prepare the sample for analysis.",
      "type": "string",
      "title": "plateWell"
    },
    "age": {
      "anyOf": [
        {
          "type": "number"
        },
        {
          "description": "Masked age values for privacy protection. Used when exact age cannot be reported due to HIPAA or other privacy regulations.",
          "enum": [
            ">= 90",
            "Unknown"
          ],
          "title": "AgeMask",
          "type": "string"
        }
      ],
      "description": "Age of the individual. Use with `ageUnit`. IMPORTANT: For human data, HIPAA requires masking ages >= 90; use the `AgeMask` value \">= 90\" instead of the exact value to protect participant privacy.",
      "title": "age"
    },
    "ageUnit": {
      "description": "",
      "enum": [
        "days",
        "hours",
        "minutes",
        "months",
        "seconds",
        "weeks",
        "years"
      ],
      "title": "ageUnit",
      "type": "string"
    },
