  "allOf": [
    {
      "if": {
        "properties": {
          "compoundDose": {}
        },
        "required": [
          "compoundDose"
        ]
      },
      "then": {
        "properties": {
          "compoundDoseUnit": {}
        },
        "required": [
          "compoundDoseUnit"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "age": {}
        },
        "required": [
          "age"
        ]
      },
      "then": {
        "properties": {
          "ageUnit": {}
        },
        "required": [
          "ageUnit"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "dataType": {}
        },
        "required": [
          "dataType"
        ]
      },
      "then": {
        "properties": {
          "dataSubtype": {}
        },
        "required": [
          "dataSubtype"
        ]
      }
    }
  ],
