{
  "$id": "https://repo-prod.prod.sagebase.org/repo/v1/schema/type/registered/org.synapse.nf-workflowreport",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "allOf": [
    {
      "if": {
        "properties": {
          "workflow": {}
        },
        "required": [
          "workflow"
        ]
      },
      "then": {
        "properties": {
          "workflowLink": {}
        },
        "required": [
          "workflowLink"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "resourceType": {
            "const": "experimentalData"
          }
        },
        "required": [
          "resourceType"
        ]
      },
      "then": {
        "properties": {
          "assay": {}
        },
        "required": [
          "assay"
        ]
      }
    }
  ],
  "description": "Template used for miscellaneous workflow reports and accessory files",
  "properties": {
    "assay": {
      "description": "The technology used to generate the data in this file.",
      "type": "string",
      "title": "assay"
    },
    "relatedDataset": {
