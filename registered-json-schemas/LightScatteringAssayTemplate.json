          "concentrationNaCl"
        ]
      },
      "then": {
        "properties": {
          "concentrationNaClUnit": {}
        },
        "required": [
          "concentrationNaClUnit"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "concentrationMaterial": {}
        },
        "required": [
          "concentrationMaterial"
        ]
      },
      "then": {
        "properties": {
          "concentrationMaterialUnit": {}
        },
        "required": [
          "concentrationMaterialUnit"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "concentrationNaCl": {}
        },
        "required": [
          "concentrationNaCl"
        ]
      },
      "then": {
        "properties": {
          "concentrationNaClUnit": {}
        },
        "required": [
          "concentrationNaClUnit"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "resourceType": {
            "const": "experimentalData"
          }
        },
        "required": [
          "resourceType"
        ]
      },
      "then": {
        "properties": {
          "platform": {},
          "specimenID": {}
        },
        "required": [
          "specimenID",
          "platform"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "resourceType": {
            "const": "experimentalData"
          }
        },
        "required": [
          "resourceType"
        ]
      },
      "then": {
        "properties": {
          "assay": {},
          "dataSubtype": {},
          "dataType": {}
        },
        "required": [
          "dataType",
          "dataSubtype",
          "assay"
        ]
      }
    }
  ],
