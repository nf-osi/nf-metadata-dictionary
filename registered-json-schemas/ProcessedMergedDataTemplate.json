{
  "$id": "https://repo-prod.prod.sagebase.org/repo/v1/schema/type/registered/org.synapse.nf-processedmergeddatatemplate",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "allOf": [
    {
      "if": {
        "properties": {
          "workflow": {}
        },
        "required": [
          "workflow"
        ]
      },
      "then": {
        "properties": {
          "workflowLink": {}
        },
        "required": [
          "workflowLink"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "resourceType": {
            "const": "experimentalData"
          }
        },
        "required": [
          "resourceType"
        ]
      },
      "then": {
        "properties": {
          "assay": {},
          "dataSubtype": {},
          "dataType": {}
        },
        "required": [
          "dataType",
          "dataSubtype",
          "assay"
        ]
      }
    }
  ],
  "description": "Further processed data with multiple samples aggregated into one file. This may be also be known as level-4 data. Unlike level-2 and level-3 data, individual-level attributes such as age and sex are no longer surfaced on the data file directly.",
  "properties": {
    "dataType": {
      "description": "Links an entity to data types that the entity represents/contains. This is closely tied to the assay property. For example, a file of dataType `genomicVariants` might have an assay value of `whole genome sequencing`.\n",
      "type": "string",
      "title": "dataType"
    },
    "dataSubtype": {
      "description": "Categorizes data based on its processing state. This is the main classification axis used for data types.  Not all data types can use this dimensions (e.g. clinical data).",
      "enum": [
        "derived",
        "normalized",
        "processed",
        "quantified",
        "raw",
        "synthetic"
      ],
      "title": "dataSubtype",
      "type": "string"
    },
    "workflow": {
      "description": "",
      "enum": [
        "CNVkit",
        "DESeq2",
        "DeepVariant",
        "FastQC",
        "FreeBayes",
        "GATK BaseRecalibration",
        "GATK MarkDuplicates",
        "MultiQC",
        "Mutect2",
        "STAR and Salmon",
        "Sarek",
        "Strelka2",
        "StringTie",
        "TrimGalore"
      ],
      "title": "workflow",
      "type": "string"
    },
    "workflowLink": {
      "description": "Workflow URL reference",
      "type": "string",
      "title": "workflowLink"
    },
    "auxiliaryAsset": {
      "description": "URI to supplemental asset(s), e.g. QC reports or other auxiliary files to support the processing, analysis, or interpretation of the current entity.\n",
      "type": "string",
      "title": "auxiliaryAsset"
    },
    "assay": {
      "description": "The technology used to generate the data in this file.",
      "type": "string",
      "title": "assay"
    },
    "fileFormat": {
      "description": "Defined format of the data file, typically corresponding to extension, but sometimes indicating more general group of files produced by the same tool or software",
      "type": "string",
