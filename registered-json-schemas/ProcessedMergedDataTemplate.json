      "title": "fileFormat"
    },
    "resourceType": {
      "description": "Resource classes. Most resource entities expected to be some type of \"experimental data\" and further specified via `dataType`.",
      "enum": [
        "experimentalData",
        "manifest",
        "metadata",
        "protocol",
        "report",
        "result",
        "tool",
        "weblink",
        "workflow report"
      ],
      "title": "resourceType",
      "type": "string"
