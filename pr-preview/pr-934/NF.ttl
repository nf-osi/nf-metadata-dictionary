<https://w3id.org/synapse/nfosi/vocab/parentSpecimenID> a linkml:SlotDefinition ;
    dcterms:title "Parent Specimen ID" ;
    skos:inScheme "https://w3id.org/nfosi/"^^xsd:anyURI ;
    linkml:definition_uri "https://w3id.org/synapse/nfosi/vocab/parentSpecimenID"^^xsd:anyURI ;
    linkml:description """A unique identifier (non-PII) that represents the parent specimen (sample) from which the data came from, e.g. the single parent tumor that was subsectioned into several samples.  The parentSpecimenID can be the same as specimenID when there is no subsectioning.
""" ;
    linkml:domain_of <https://w3id.org/synapse/nfosi/vocab/BiospecimenTemplate>,
        <https://w3id.org/synapse/nfosi/vocab/CellTissuePhenotypingTemplate>,
        <https://w3id.org/synapse/nfosi/vocab/GeneticsAssayTemplate>,
        <https://w3id.org/synapse/nfosi/vocab/MicroscopyAssayTemplate>,
        <https://w3id.org/synapse/nfosi/vocab/PlateBasedReporterAssayTemplate>,
        <https://w3id.org/synapse/nfosi/vocab/ProteinAssayTemplate>,
        <https://w3id.org/synapse/nfosi/vocab/SpatialTranscriptomicsImagingTemplate> ;
    linkml:owner <https://w3id.org/synapse/nfosi/vocab/SpatialTranscriptomicsImagingTemplate> ;
    linkml:range <https://w3id.org/synapse/nfosi/vocab/string> ;
    linkml:slot_uri "https://w3id.org/synapse/nfosi/vocab/parentSpecimenID"^^xsd:anyURI ;
    linkml:value_presence [ a linkml:PermissibleValue ;
            skos:notation "PRESENT" ],
        [ a linkml:PermissibleValue ;
            skos:notation "PRESENT" ] .

<https://w3id.org/synapse/nfosi/vocab/GeneticsAssayTemplate> a linkml:ClassDefinition ;
    skos:editorialNote "http://purl.obolibrary.org/obo/GECKO_0000032" ;
    skos:inScheme "https://w3id.org/nfosi/"^^xsd:anyURI ;
    sh:rule [ a linkml:ClassRule ;
            sh:condition [ a linkml:AnonymousClassExpression ;
                    linkml:slot_conditions <https://w3id.org/synapse/nfosi/vocab/resourceType> ] ;
            linkml:description "Relaxed conditional validation (issue #825): the listed fields are required only for experimentalData. Auxiliary co-located files (manifest, metadata, report, workflow report, tool, result, weblink, protocol) are exempt." ;
            linkml:postconditions [ a linkml:AnonymousClassExpression ;
                    linkml:slot_conditions <https://w3id.org/synapse/nfosi/vocab/platform>,
                        <https://w3id.org/synapse/nfosi/vocab/specimenID>,
                        <https://w3id.org/synapse/nfosi/vocab/specimenPreparationMethod> ] ] ;
    linkml:abstract true ;
    linkml:class_uri "https://w3id.org/synapse/nfosi/vocab/GeneticsAssayTemplate"^^xsd:anyURI ;
    linkml:definition_uri "https://w3id.org/synapse/nfosi/vocab/GeneticsAssayTemplate"^^xsd:anyURI ;
    linkml:description """Template for relatively raw data of RNA/DNA structure and expression.  This is an abstract template encapsulating data from low-throughput to high-throughput assays,  sequencing-based or non-sequencing based (e.g. microarrays, optical genome mapping).  In practice, data are more specifically typed and matched to one of the templates below.
""" ;
    linkml:is_a <https://w3id.org/synapse/nfosi/vocab/BiologicalAssayDataTemplate> ;
    linkml:slot_usage [ ] ;
    linkml:slots <https://w3id.org/synapse/nfosi/vocab/BiologicalAssayDataTemplate_dataSubtype>,
