<https://w3id.org/synapse/nfosi/vocab/bodySite> a linkml:SlotDefinition ;
    dcterms:title "Body Site" ;
    skos:inScheme "https://w3id.org/nfosi/"^^xsd:anyURI ;
    skos:mappingRelation "https://cancerdhc.github.io/ccdhmodel/v1.1/BodySite/"^^xsd:anyURI ;
    skos:note "Helpful to consider where /cell samples came from, e.g. something like \"schwannoma\" gets put in `tumorType`, but `bodySite` gives us the original location of the tumor." ;
    linkml:definition_uri "https://w3id.org/synapse/nfosi/vocab/bodySite"^^xsd:anyURI ;
    linkml:description "Sample location referring to a named area of the body, inclusive of gross anatomical structures and organ parts." ;
    linkml:domain_of <https://w3id.org/synapse/nfosi/vocab/BiospecimenTemplate>,
        <https://w3id.org/synapse/nfosi/vocab/ElectrophysiologyAssayTemplate>,
        <https://w3id.org/synapse/nfosi/vocab/MRIAssayTemplate> ;
    linkml:owner <https://w3id.org/synapse/nfosi/vocab/MRIAssayTemplate> ;
    linkml:range <https://w3id.org/synapse/nfosi/vocab/BodyPartEnum> ;
    linkml:slot_uri "https://cancerdhc.github.io/ccdhmodel/v1.1/BodySite/"^^xsd:anyURI .

