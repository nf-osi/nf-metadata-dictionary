        "Visium" ;
    linkml:description "10x Genomics product that includes special slides, reagents and technology to allow whole transcriptome profiling with morphological (spatial) context in FFPE or fresh-frozen tissues. Vendor ref: https://www.10xgenomics.com/products/spatial-gene-expression" ;
    linkml:meaning "EFO:0010961"^^xsd:anyURI .

