<https://w3id.org/synapse/nfosi/vocab/ProcessedAlignedReadsTemplate> a linkml:ClassDefinition ;
    skos:closeMatch "htan:BulkRNA-seqLevel2"^^xsd:anyURI,
        "htan:BulkWESLevel2"^^xsd:anyURI,
        "htan:ScRNA-seqLevel2"^^xsd:anyURI ;
    skos:inScheme "https://w3id.org/nfosi/"^^xsd:anyURI ;
    sh:rule [ a linkml:ClassRule ;
            sh:condition [ a linkml:AnonymousClassExpression ;
                    linkml:slot_conditions <https://w3id.org/synapse/nfosi/vocab/genomicReference> ] ;
            linkml:description "If genomicReference is provided, genomicReferenceLink must be provided" ;
            linkml:postconditions [ a linkml:AnonymousClassExpression ;
                    linkml:slot_conditions <https://w3id.org/synapse/nfosi/vocab/genomicReferenceLink> ] ],
        [ a linkml:ClassRule ;
            sh:condition [ a linkml:AnonymousClassExpression ;
                    linkml:slot_conditions <https://w3id.org/synapse/nfosi/vocab/resourceType> ] ;
            linkml:description "Relaxed conditional validation (issue #825): the listed fields are required only for experimentalData. Auxiliary co-located files (manifest, metadata, report, workflow report, tool, result, weblink, protocol) are exempt." ;
            linkml:postconditions [ a linkml:AnonymousClassExpression ;
                    linkml:slot_conditions <https://w3id.org/synapse/nfosi/vocab/genomicReference>,
                        <https://w3id.org/synapse/nfosi/vocab/specimenID> ] ],
        [ a linkml:ClassRule ;
            sh:condition [ a linkml:AnonymousClassExpression ;
                    linkml:slot_conditions <https://w3id.org/synapse/nfosi/vocab/workflow> ] ;
            linkml:description "If workflow is provided, workflowLink must be provided" ;
            linkml:postconditions [ a linkml:AnonymousClassExpression ;
                    linkml:slot_conditions <https://w3id.org/synapse/nfosi/vocab/workflowLink> ] ] ;
    linkml:class_uri "https://w3id.org/synapse/nfosi/vocab/ProcessedAlignedReadsTemplate"^^xsd:anyURI ;
    linkml:definition_uri "https://w3id.org/synapse/nfosi/vocab/ProcessedAlignedReadsTemplate"^^xsd:anyURI ;
    linkml:description "Template for describing aligned reads (e.g. BAM/CRAM files) from a sequencing assay. The QC meta are extracted from samtools stats when available and are the same metrics preferred by GDC." ;
    linkml:is_a <https://w3id.org/synapse/nfosi/vocab/BiologicalAssayDataTemplate> ;
    linkml:slot_usage [ ] ;
    linkml:slots <https://w3id.org/synapse/nfosi/vocab/BiologicalAssayDataTemplate_assay>,
        <https://w3id.org/synapse/nfosi/vocab/BiologicalAssayDataTemplate_diagnosis>,
        <https://w3id.org/synapse/nfosi/vocab/BiologicalAssayDataTemplate_individualID>,
        <https://w3id.org/synapse/nfosi/vocab/BiologicalAssayDataTemplate_species>,
        <https://w3id.org/synapse/nfosi/vocab/BiologicalAssayDataTemplate_tumorType>,
        <https://w3id.org/synapse/nfosi/vocab/Component>,
        <https://w3id.org/synapse/nfosi/vocab/Filename>,
        <https://w3id.org/synapse/nfosi/vocab/ProcessedAlignedReadsTemplate_dataSubtype>,
        <https://w3id.org/synapse/nfosi/vocab/ProcessedAlignedReadsTemplate_dataType>,
        <https://w3id.org/synapse/nfosi/vocab/ProcessedAlignedReadsTemplate_fileFormat>,
        <https://w3id.org/synapse/nfosi/vocab/ProcessedAlignedReadsTemplate_genomicReference>,
        <https://w3id.org/synapse/nfosi/vocab/ProcessedAlignedReadsTemplate_specimenID>,
        <https://w3id.org/synapse/nfosi/vocab/age>,
        <https://w3id.org/synapse/nfosi/vocab/ageUnit>,
        <https://w3id.org/synapse/nfosi/vocab/antibodyID>,
        <https://w3id.org/synapse/nfosi/vocab/auxiliaryAsset>,
        <https://w3id.org/synapse/nfosi/vocab/averageBaseQuality>,
        <https://w3id.org/synapse/nfosi/vocab/averageInsertSize>,
        <https://w3id.org/synapse/nfosi/vocab/averageReadLength>,
        <https://w3id.org/synapse/nfosi/vocab/comments>,
        <https://w3id.org/synapse/nfosi/vocab/geneticReagentID>,
        <https://w3id.org/synapse/nfosi/vocab/genomicReferenceLink>,
        <https://w3id.org/synapse/nfosi/vocab/meanCoverage>,
        <https://w3id.org/synapse/nfosi/vocab/nf1Genotype>,
        <https://w3id.org/synapse/nfosi/vocab/nf2Genotype>,
