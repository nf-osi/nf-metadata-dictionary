<https://w3id.org/synapse/nfosi/vocab/ScSequencingAssayTemplate_libraryStrand> a linkml:SlotDefinition ;
    dcterms:title "Library Strand" ;
    skos:editorialNote "Meaning originally captured with combination of readPairOrientation and readStrandOrigin.",
        "https://littlebitofdata.com/en/2017/08/strandness_in_rnaseq/" ;
    skos:inScheme "https://w3id.org/nfosi/"^^xsd:anyURI ;
    skos:prefLabel "libraryStrand" ;
    linkml:any_of [ a linkml:AnonymousSlotExpression ;
            linkml:range <https://w3id.org/synapse/nfosi/vocab/NotApplicableEnum> ],
        [ a linkml:AnonymousSlotExpression ;
            linkml:range <https://w3id.org/synapse/nfosi/vocab/StrandednessEnum> ] ;
    linkml:definition_uri "https://w3id.org/synapse/nfosi/vocab/libraryStrand"^^xsd:anyURI ;
    linkml:description "Strandedness of paired-end RNA-Sequencing data. This is an important parameter for RNA-seq analysis." ;
    linkml:domain <https://w3id.org/synapse/nfosi/vocab/ScSequencingAssayTemplate> ;
    linkml:domain_of <https://w3id.org/synapse/nfosi/vocab/ScSequencingAssayTemplate> ;
    linkml:is_a <https://w3id.org/synapse/nfosi/vocab/libraryStrand> ;
    linkml:is_usage_slot true ;
    linkml:owner <https://w3id.org/synapse/nfosi/vocab/ScSequencingAssayTemplate> ;
    linkml:range <https://w3id.org/synapse/nfosi/vocab/string> ;
    linkml:required true ;
    linkml:slot_uri "https://w3id.org/synapse/nfosi/vocab/libraryStrand"^^xsd:anyURI ;
    linkml:usage_slot_name "libraryStrand" .

<https://w3id.org/synapse/nfosi/vocab/ScSequencingAssayTemplate_platform> a linkml:SlotDefinition ;
    dcterms:title "Platform" ;
    skos:inScheme "https://w3id.org/nfosi/"^^xsd:anyURI ;
    skos:prefLabel "platform" ;
    linkml:any_of [ a linkml:AnonymousSlotExpression ;
            linkml:range <https://w3id.org/synapse/nfosi/vocab/MRIPlatformEnum> ],
        [ a linkml:AnonymousSlotExpression ;
            linkml:range <https://w3id.org/synapse/nfosi/vocab/string> ],
        [ a linkml:AnonymousSlotExpression ;
            linkml:range <https://w3id.org/synapse/nfosi/vocab/OtherPlatformEnum> ],
        [ a linkml:AnonymousSlotExpression ;
            linkml:range <https://w3id.org/synapse/nfosi/vocab/ArrayPlatformEnum> ],
        [ a linkml:AnonymousSlotExpression ;
            linkml:range <https://w3id.org/synapse/nfosi/vocab/SequencingPlatformEnum> ],
        [ a linkml:AnonymousSlotExpression ;
            linkml:range <https://w3id.org/synapse/nfosi/vocab/PlateReaderPlatformEnum> ],
        [ a linkml:AnonymousSlotExpression ;
            linkml:range <https://w3id.org/synapse/nfosi/vocab/MassSpectrometryPlatformEnum> ],
        [ a linkml:AnonymousSlotExpression ;
            linkml:range <https://w3id.org/synapse/nfosi/vocab/MicroscopyImagingPlatformEnum> ],
        [ a linkml:AnonymousSlotExpression ;
            linkml:range <https://w3id.org/synapse/nfosi/vocab/ImagingSystemPlatformEnum> ],
        [ a linkml:AnonymousSlotExpression ;
            linkml:range <https://w3id.org/synapse/nfosi/vocab/FlowCytometryPlatformEnum> ] ;
    linkml:definition_uri "https://w3id.org/synapse/nfosi/vocab/platform"^^xsd:anyURI ;
    linkml:description "A sequencing platform, microscope, spectroscope/plate reader, or other platform for collecting data. Select from the recommended list when available or enter a custom name." ;
    linkml:domain <https://w3id.org/synapse/nfosi/vocab/ScSequencingAssayTemplate> ;
    linkml:domain_of <https://w3id.org/synapse/nfosi/vocab/ScSequencingAssayTemplate> ;
    linkml:is_a <https://w3id.org/synapse/nfosi/vocab/GeneticsAssayTemplate_platform> ;
    linkml:is_usage_slot true ;
    linkml:owner <https://w3id.org/synapse/nfosi/vocab/ScSequencingAssayTemplate> ;
    linkml:range <https://w3id.org/synapse/nfosi/vocab/SequencingPlatformEnum> ;
    linkml:required true ;
    linkml:slot_uri "https://w3id.org/synapse/nfosi/vocab/platform"^^xsd:anyURI ;
    linkml:usage_slot_name "platform" .

