<https://w3id.org/synapse/nfosi/vocab/MaterialScienceAssayTemplate> a linkml:ClassDefinition ;
    skos:inScheme "https://w3id.org/nfosi/"^^xsd:anyURI ;
    sh:rule [ a linkml:ClassRule ;
            sh:condition [ a linkml:AnonymousClassExpression ;
                    linkml:slot_conditions <https://w3id.org/synapse/nfosi/vocab/concentrationNaCl> ] ;
            linkml:description "If concentrationNaCl is provided, concentrationNaClUnit must be provided" ;
            linkml:postconditions [ a linkml:AnonymousClassExpression ;
                    linkml:slot_conditions <https://w3id.org/synapse/nfosi/vocab/concentrationNaClUnit> ] ],
        [ a linkml:ClassRule ;
            sh:condition [ a linkml:AnonymousClassExpression ;
                    linkml:slot_conditions <https://w3id.org/synapse/nfosi/vocab/concentrationMaterial> ] ;
            linkml:description "If concentrationMaterial is provided, concentrationMaterialUnit must be provided" ;
            linkml:postconditions [ a linkml:AnonymousClassExpression ;
                    linkml:slot_conditions <https://w3id.org/synapse/nfosi/vocab/concentrationMaterialUnit> ] ],
        [ a linkml:ClassRule ;
            sh:condition [ a linkml:AnonymousClassExpression ;
                    linkml:slot_conditions <https://w3id.org/synapse/nfosi/vocab/resourceType> ] ;
            linkml:description "Relaxed conditional validation (issue #825): the listed fields are required only for experimentalData. Auxiliary co-located files (manifest, metadata, report, workflow report, tool, result, weblink, protocol) are exempt." ;
            linkml:postconditions [ a linkml:AnonymousClassExpression ;
                    linkml:slot_conditions <https://w3id.org/synapse/nfosi/vocab/platform>,
                        <https://w3id.org/synapse/nfosi/vocab/specimenID> ] ] ;
    linkml:class_uri "https://w3id.org/synapse/nfosi/vocab/MaterialScienceAssayTemplate"^^xsd:anyURI ;
    linkml:definition_uri "https://w3id.org/synapse/nfosi/vocab/MaterialScienceAssayTemplate"^^xsd:anyURI ;
    linkml:description "General template for describing data for a materials science assay." ;
    linkml:is_a <https://w3id.org/synapse/nfosi/vocab/NonBiologicalAssayDataTemplate> ;
    linkml:slot_usage [ ] ;
