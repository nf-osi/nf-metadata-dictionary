<https://w3id.org/synapse/nfosi/vocab/CellTissuePhenotypingTemplate_specimenID> a linkml:SlotDefinition ;
    dcterms:title "Specimen ID" ;
    skos:inScheme "https://w3id.org/nfosi/"^^xsd:anyURI ;
    skos:prefLabel "specimenID" ;
    linkml:definition_uri "https://w3id.org/synapse/nfosi/vocab/specimenID"^^xsd:anyURI ;
    linkml:description """A unique identifier (non-PII) that represents the subspecimen (subsample) from which the data came,  e.g. an ID that distinguishes between different parts of the same parent tumor specimen.
""" ;
    linkml:domain <https://w3id.org/synapse/nfosi/vocab/CellTissuePhenotypingTemplate> ;
    linkml:domain_of <https://w3id.org/synapse/nfosi/vocab/CellTissuePhenotypingTemplate> ;
    linkml:is_a <https://w3id.org/synapse/nfosi/vocab/specimenID> ;
    linkml:is_usage_slot true ;
    linkml:owner <https://w3id.org/synapse/nfosi/vocab/CellTissuePhenotypingTemplate> ;
    linkml:range <https://w3id.org/synapse/nfosi/vocab/string> ;
    linkml:required true ;
    linkml:slot_uri "https://w3id.org/synapse/nfosi/vocab/specimenID"^^xsd:anyURI ;
    linkml:usage_slot_name "specimenID" .

<https://w3id.org/synapse/nfosi/vocab/ChIPSeqTemplate_assay> a linkml:SlotDefinition ;
    dcterms:title "Assay" ;
    skos:inScheme "https://w3id.org/nfosi/"^^xsd:anyURI ;
    skos:prefLabel "assay" ;
    linkml:any_of [ a linkml:AnonymousSlotExpression ;
            linkml:range <https://w3id.org/synapse/nfosi/vocab/SequencingAssayEnum> ],
        [ a linkml:AnonymousSlotExpression ;
            linkml:range <https://w3id.org/synapse/nfosi/vocab/ImagingAssayEnum> ],
        [ a linkml:AnonymousSlotExpression ;
            linkml:range <https://w3id.org/synapse/nfosi/vocab/MassSpectrometryAssayEnum> ],
        [ a linkml:AnonymousSlotExpression ;
            linkml:range <https://w3id.org/synapse/nfosi/vocab/ClinicalBehavioralAssayEnum> ],
        [ a linkml:AnonymousSlotExpression ;
            linkml:range <https://w3id.org/synapse/nfosi/vocab/DrugScreenAssayEnum> ],
        [ a linkml:AnonymousSlotExpression ;
            linkml:range <https://w3id.org/synapse/nfosi/vocab/CellBasedAssayEnum> ] ;
    linkml:definition_uri "https://w3id.org/synapse/nfosi/vocab/assay"^^xsd:anyURI ;
    linkml:description "The technology used to generate the data in this file." ;
    linkml:domain <https://w3id.org/synapse/nfosi/vocab/ChIPSeqTemplate> ;
    linkml:domain_of <https://w3id.org/synapse/nfosi/vocab/ChIPSeqTemplate> ;
    linkml:ifabsent "string(ChIP-seq)" ;
    linkml:is_a <https://w3id.org/synapse/nfosi/vocab/EpigenomicsAssayTemplate_assay> ;
    linkml:is_usage_slot true ;
    linkml:owner <https://w3id.org/synapse/nfosi/vocab/ChIPSeqTemplate> ;
    linkml:range <https://w3id.org/synapse/nfosi/vocab/SequencingAssayEnum> ;
    linkml:required true ;
    linkml:slot_uri "https://w3id.org/synapse/nfosi/vocab/assay"^^xsd:anyURI ;
    linkml:usage_slot_name "assay" .

