    linkml:domain_of <https://w3id.org/synapse/nfosi/vocab/PortalDataset> ;
    linkml:multivalued true ;
    linkml:owner <https://w3id.org/synapse/nfosi/vocab/PortalDataset> ;
    linkml:range <https://w3id.org/synapse/nfosi/vocab/Data> ;
    linkml:required true ;
    linkml:slot_uri "https://w3id.org/synapse/nfosi/vocab/dataType"^^xsd:anyURI .

<https://w3id.org/synapse/nfosi/vocab/portalDataset__dataUseModifiers> a linkml:SlotDefinition ;
    dcterms:title "Data Use Modifiers" ;
    skos:inScheme "https://w3id.org/nfosi/"^^xsd:anyURI ;
    skos:prefLabel "dataUseModifiers" ;
    linkml:description "List of data use ontology (DUO) terms that are true for dataset, which describes the allowable scope and terms for data use. Most datasets allow \"General Research Use\" unless otherwise specified." ;
    linkml:domain_of <https://w3id.org/synapse/nfosi/vocab/PortalDataset> ;
    linkml:multivalued true ;
    linkml:owner <https://w3id.org/synapse/nfosi/vocab/PortalDataset> ;
    linkml:range <https://w3id.org/synapse/nfosi/vocab/DuoEnum> ;
    linkml:slot_uri "https://w3id.org/synapse/nfosi/vocab/dataUseModifiers"^^xsd:anyURI .

<https://w3id.org/synapse/nfosi/vocab/portalDataset__datePublished> a linkml:SlotDefinition ;
