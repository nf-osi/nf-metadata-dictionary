<https://w3id.org/synapse/nfosi/vocab/volume> skos:altLabel "Total Volume",
        "Vol" ;
    linkml:description "Data of the three dimensional space occupied by an entity or the capacity of a space or container." ;
    linkml:meaning "NCIT:C25335"^^xsd:anyURI .

<https://w3id.org/synapse/nfosi/vocab/weblink> skos:altLabel "URL",
        "Uniform Resource Locator" ;
