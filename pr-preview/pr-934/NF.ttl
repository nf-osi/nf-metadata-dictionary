    linkml:meaning "EDAM:format_3016"^^xsd:anyURI .

<https://w3id.org/synapse/nfosi/vocab/bed> linkml:description "Browser Extensible Data (BED) format of sequence annotation track, typically to be displayed in a genome browser" ;
    linkml:meaning "EDAM:format_3003"^^xsd:anyURI .

<https://w3id.org/synapse/nfosi/vocab/bed%20broadPeak> dcterms:source "http://genome.ucsc.edu/FAQ/FAQformat.html#format13"^^xsd:anyURI ;
    linkml:description "This format is used to provide called regions of signal enrichment based on pooled, normalized (interpreted) data. It is a BED 6+3 format." .

<https://w3id.org/synapse/nfosi/vocab/bed%20gappedPeak> dcterms:source "http://genome.ucsc.edu/FAQ/FAQformat.html#format14"^^xsd:anyURI ;
    linkml:description "This format is used to provide called regions of signal enrichment based on pooled, normalized (interpreted) data where the regions may be spliced or incorporate gaps in the genomic sequence. It is a BED12+3 format." .

<https://w3id.org/synapse/nfosi/vocab/bed%20narrowPeak> dcterms:source "http://genome.ucsc.edu/FAQ/FAQformat.html#format12"^^xsd:anyURI ;
    linkml:description "This format is used to provide called peaks of signal enrichment based on pooled, normalized (interpreted) data. It is a BED6+4 format." .

<https://w3id.org/synapse/nfosi/vocab/bedgraph> linkml:description "Holds a tab-delimited chromosome /start /end / datavalue dataset. The bedGraph format allows display of continuous-valued data in track format. This display type is useful for probability scores and transcriptome data" ;
    linkml:meaning "EDAM:format_3583"^^xsd:anyURI .

<https://w3id.org/synapse/nfosi/vocab/behavioral%20data> skos:altLabel "behavior process" ;
