    linkml:definition_uri "https://w3id.org/synapse/nfosi/vocab/libraryStrand"^^xsd:anyURI ;
    linkml:description "Strandedness of paired-end RNA-Sequencing data. This is an important parameter for RNA-seq analysis." ;
