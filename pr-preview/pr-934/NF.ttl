        [ a linkml:AnonymousSlotExpression ;
            linkml:range <https://w3id.org/synapse/nfosi/vocab/Genotype> ] ;
    linkml:definition_uri "https://w3id.org/synapse/nfosi/vocab/nf1Genotype"^^xsd:anyURI ;
    linkml:description "Genotype of NF1 gene in the biospecimen from which the data were derived, if known." ;
    linkml:domain_of <https://w3id.org/synapse/nfosi/vocab/AnimalIndividualTemplate>,
        <https://w3id.org/synapse/nfosi/vocab/BiologicalAssayDataTemplate>,
        <https://w3id.org/synapse/nfosi/vocab/HumanCohortTemplate> ;
    linkml:owner <https://w3id.org/synapse/nfosi/vocab/BiologicalAssayDataTemplate> ;
    linkml:range <https://w3id.org/synapse/nfosi/vocab/string> ;
    linkml:slot_uri "https://w3id.org/synapse/nfosi/vocab/nf1Genotype"^^xsd:anyURI .

<https://w3id.org/synapse/nfosi/vocab/nf2Genotype> a linkml:SlotDefinition ;
