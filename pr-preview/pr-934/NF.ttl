<https://w3id.org/synapse/nfosi/vocab/PdxGenomicsAssayTemplate> a linkml:ClassDefinition ;
    skos:inScheme "https://w3id.org/nfosi/"^^xsd:anyURI ;
    sh:rule [ a linkml:ClassRule ;
            sh:condition [ a linkml:AnonymousClassExpression ;
                    linkml:slot_conditions <https://w3id.org/synapse/nfosi/vocab/transplantationType> ] ;
            linkml:description "If transplantationType is provided, transplantationRecipientTissue must be provided" ;
            linkml:postconditions [ a linkml:AnonymousClassExpression ;
                    linkml:slot_conditions <https://w3id.org/synapse/nfosi/vocab/transplantationRecipientTissue> ] ],
        [ a linkml:ClassRule ;
            sh:condition [ a linkml:AnonymousClassExpression ;
                    linkml:slot_conditions <https://w3id.org/synapse/nfosi/vocab/experimentalTimepoint> ] ;
            linkml:description "If experimentalTimepoint is provided, timepointUnit must be provided" ;
            linkml:postconditions [ a linkml:AnonymousClassExpression ;
                    linkml:slot_conditions <https://w3id.org/synapse/nfosi/vocab/timepointUnit> ] ],
        [ a linkml:ClassRule ;
            sh:condition [ a linkml:AnonymousClassExpression ;
                    linkml:slot_conditions <https://w3id.org/synapse/nfosi/vocab/modelAge> ] ;
            linkml:description "If modelAge is provided, modelAgeUnit must be provided" ;
            linkml:postconditions [ a linkml:AnonymousClassExpression ;
                    linkml:slot_conditions <https://w3id.org/synapse/nfosi/vocab/modelAgeUnit> ] ],
        [ a linkml:ClassRule ;
            sh:condition [ a linkml:AnonymousClassExpression ;
                    linkml:slot_conditions <https://w3id.org/synapse/nfosi/vocab/transplantationType> ] ;
            linkml:description "If transplantationType is provided, transplantationRecipientSpecies must be provided" ;
            linkml:postconditions [ a linkml:AnonymousClassExpression ;
                    linkml:slot_conditions <https://w3id.org/synapse/nfosi/vocab/transplantationRecipientSpecies> ] ] ;
