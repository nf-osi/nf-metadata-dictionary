<https://w3id.org/synapse/nfosi/vocab/ScRNASeqTemplate> a linkml:ClassDefinition ;
    skos:inScheme "https://w3id.org/nfosi/"^^xsd:anyURI ;
    sh:rule [ a linkml:ClassRule ;
            sh:condition [ a linkml:AnonymousClassExpression ;
                    linkml:slot_conditions <https://w3id.org/synapse/nfosi/vocab/genePerturbed> ] ;
            linkml:description "If genePerturbed is provided, genePerturbationType must be provided" ;
            linkml:postconditions [ a linkml:AnonymousClassExpression ;
                    linkml:slot_conditions <https://w3id.org/synapse/nfosi/vocab/genePerturbationType> ] ],
        [ a linkml:ClassRule ;
            sh:condition [ a linkml:AnonymousClassExpression ;
                    linkml:slot_conditions <https://w3id.org/synapse/nfosi/vocab/genePerturbed> ] ;
            linkml:description "If genePerturbed is provided, genePerturbationTechnology must be provided" ;
            linkml:postconditions [ a linkml:AnonymousClassExpression ;
                    linkml:slot_conditions <https://w3id.org/synapse/nfosi/vocab/genePerturbationTechnology> ] ] ;
    linkml:class_uri "https://w3id.org/synapse/nfosi/vocab/ScRNASeqTemplate"^^xsd:anyURI ;
    linkml:definition_uri "https://w3id.org/synapse/nfosi/vocab/ScRNASeqTemplate"^^xsd:anyURI ;
