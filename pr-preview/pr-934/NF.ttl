<https://w3id.org/synapse/nfosi/vocab/MassSpecAssayTemplate> a linkml:ClassDefinition ;
    skos:closeMatch "htan:MassSpectrometryLevel1"^^xsd:anyURI ;
    skos:editorialNote "Technically, mass spec does not have to be considered a biological assay, but we'll classify it as such when used with a biological sample." ;
