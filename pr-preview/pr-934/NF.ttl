    linkml:description "The longest single nerve that is formed by the merging of the ventral rami of the L4, L5, and S1 in the pelvis and passes down the lower limb where it divides into the common peroneal and tibial nerves" ;
    linkml:meaning "BTO:0001221"^^xsd:anyURI .

<https://w3id.org/synapse/nfosi/vocab/sdf> linkml:description "SDF is one of a family of chemical-data file formats developed by MDL Information Systems; it is intended especially for structural information." ;
    linkml:meaning "EDAM:format_3814"^^xsd:anyURI .

<https://w3id.org/synapse/nfosi/vocab/seconds> skos:altLabel "s" ;
    linkml:meaning "UO:0000010"^^xsd:anyURI .

<https://w3id.org/synapse/nfosi/vocab/seg> dcterms:source "https://software.broadinstitute.org/software/igv/SEG"^^xsd:anyURI ;
    linkml:description "SEG file (segmented data; .seg or .cbs) is a tab-delimited text file that lists loci and associated numeric values" .

<https://w3id.org/synapse/nfosi/vocab/serum> linkml:description "Liquid derived from blood plasma that has clotting factors removed." ;
    linkml:meaning "BTO:0001239"^^xsd:anyURI .

<https://w3id.org/synapse/nfosi/vocab/sf> dcterms:source "https://salmon.readthedocs.io/en/latest/file_formats.html"^^xsd:anyURI ;
    linkml:description "Salmon's main output is its quantification file. This file is a plain-text, tab-separated file with a single header line (which names all of the columns)." .

<https://w3id.org/synapse/nfosi/vocab/shRNA-seq> skos:altLabel "shRNA library screen sequencing" ;
    linkml:description "A sequencing-based functional genomics assay in which a pooled short hairpin RNA (shRNA) library is introduced into cells, and the relative abundance of individual shRNA constructs is quantified by amplicon sequencing to identify genes affecting a phenotype of interest." ;
    linkml:meaning "EFO:0030034"^^xsd:anyURI .

<https://w3id.org/synapse/nfosi/vocab/shoulder> linkml:description "" .

<https://w3id.org/synapse/nfosi/vocab/sif> linkml:description "SIF (simple interaction file) Format - a network/pathway format used for instance in cytoscape" ;
    linkml:meaning "EDAM:format_3619"^^xsd:anyURI .

<https://w3id.org/synapse/nfosi/vocab/single%20cell> dcterms:source "https://github.com/HumanCellAtlas/metadata-schema/blob/master/json_schema/type/process/sequencing/library_preparation_process.json"^^xsd:anyURI ;
    linkml:description "Single cell" .

<https://w3id.org/synapse/nfosi/vocab/single%20cell%20ATAC-seq> skos:altLabel "scATAC-Seq" ;
    linkml:description "A molecular genetic technique where DNA is isolated from single cell (sc) samples and amplified to create a genomic library. Then the library is subjected to ATAC-seq, which isolates and sequences regions rich in open chromatin." ;
    linkml:meaning "NCIT:C179458"^^xsd:anyURI .

<https://w3id.org/synapse/nfosi/vocab/single%20nucleus> dcterms:source "https://github.com/HumanCellAtlas/metadata-schema/blob/master/json_schema/type/process/sequencing/library_preparation_process.json"^^xsd:anyURI ;
    linkml:description "Single nuclei" .

<https://w3id.org/synapse/nfosi/vocab/single-cell%20RNA-seq> skos:altLabel "Single Cell RNA Sequencing",
        "Single Cell Transcriptome Sequencing",
        "scRNA-Seq" ;
    linkml:description "A procedure that can determine the nucleotide sequence for all of the RNA transcripts in an amplified nucleotide sample that was derived from a single cell." ;
    linkml:meaning "NCIT:C171152"^^xsd:anyURI .

<https://w3id.org/synapse/nfosi/vocab/single-nucleus%20RNA-seq> skos:altLabel "single-nucleus RNA sequencing assay",
        "snRNA-Seq" ;
    linkml:description "A method for quantifying the transcriptome of individual cells, in which transcripts isolated from single nuclei are subjected to high-throughput sequencing and mapping to a reference genome." ;
    linkml:meaning "FBcv:0009001"^^xsd:anyURI .

<https://w3id.org/synapse/nfosi/vocab/singleEnd> linkml:description "A library preparation that results in the creation of a library of 5' ends of DNA." .

<https://w3id.org/synapse/nfosi/vocab/six-minute%20walk%20test> dcterms:source "https://www.ncbi.nlm.nih.gov/books/NBK576420/"^^xsd:anyURI ;
    linkml:description "The six-minute walk test (6MWT) is a simple, standardized functional assay of exercise capacity that measures how far the human subject can walk within a 6-minute duration; used to to evaluate lung and heart conditions." .

<https://w3id.org/synapse/nfosi/vocab/skin> linkml:description "The integument of an animal (as a fur-bearing mammal or a bird) separated from the body usually with its hair or feathers." ;
    linkml:meaning "BTO:0001253"^^xsd:anyURI .

<https://w3id.org/synapse/nfosi/vocab/slideID> a linkml:SlotDefinition ;
    dcterms:title "Slide ID" ;
    skos:inScheme "https://w3id.org/nfosi/"^^xsd:anyURI ;
    linkml:definition_uri "https://w3id.org/synapse/nfosi/vocab/slideID"^^xsd:anyURI ;
    linkml:description """Unique identifier printed on the label of each Visium slide. The serial number starts with V followed by a number which can range between one through five and ends with a dash and a three digit number, such as 123.
""" ;
    linkml:range <https://w3id.org/synapse/nfosi/vocab/string> ;
    linkml:slot_uri "https://w3id.org/synapse/nfosi/vocab/slideID"^^xsd:anyURI .

<https://w3id.org/synapse/nfosi/vocab/slideVersion> a linkml:SlotDefinition ;
    dcterms:title "Slide Version" ;
    skos:inScheme "https://w3id.org/nfosi/"^^xsd:anyURI ;
    linkml:definition_uri "https://w3id.org/synapse/nfosi/vocab/slideVersion"^^xsd:anyURI ;
    linkml:description "Version of imaging slide used. Slide version is critical for the analysis of the sequencing data as different slides have different capture area layouts." ;
    linkml:range <https://w3id.org/synapse/nfosi/vocab/string> ;
    linkml:slot_uri "https://w3id.org/synapse/nfosi/vocab/slideVersion"^^xsd:anyURI .

<https://w3id.org/synapse/nfosi/vocab/smooth%20muscle> linkml:description "Muscle tissue that lacks cross striations, that is made up of elongated spindle-shaped cells having a central nucleus, and that is found in vertebrate visceral structures (as the stomach and bladder) as thin sheets performing functions not subject to conscious control by the mind and in all or most of the musculature of invertebrates other than arthropods." ;
    linkml:meaning "BTO:0001260"^^xsd:anyURI .

<https://w3id.org/synapse/nfosi/vocab/somatic%20variants> dcterms:source "https://w3id.org/synapse/nfosi/vocab/SomaticVariants"^^xsd:anyURI ;
    linkml:description "Called somatic variants" .

<https://w3id.org/synapse/nfosi/vocab/sorbitol%20dehydrogenase%20activity%20level%20assay> linkml:description "An enzymatic activity level assay that measures the activity of sorbitol dehydrogenase in a sample." ;
    linkml:meaning "OBI:0003434"^^xsd:anyURI .

<https://w3id.org/synapse/nfosi/vocab/sourceName> a linkml:SlotDefinition ;
    dcterms:title "Source Name" ;
    skos:inScheme "https://w3id.org/nfosi/"^^xsd:anyURI ;
    linkml:definition_uri "https://w3id.org/synapse/nfosi/vocab/sourceName"^^xsd:anyURI ;
    linkml:description """Intended for non-biological samples, tf the sample is a nanoparticle sample or some chemical substance not derived from a biological material,  the corresponding source name should refer to the starting sample that was modified by a protocol for the assay.
""" ;
    linkml:range <https://w3id.org/synapse/nfosi/vocab/string> ;
    linkml:slot_uri "https://w3id.org/synapse/nfosi/vocab/sourceName"^^xsd:anyURI .

<https://w3id.org/synapse/nfosi/vocab/sparqlpath> a linkml:TypeDefinition ;
    dcterms:conformsTo "https://www.w3.org/TR/sparql11-query/#propertypaths" ;
    skos:editorialNote "If you are authoring schemas in LinkML YAML, the type is referenced with the lower case \"sparqlpath\"." ;
    skos:inScheme "https://w3id.org/linkml/types"^^xsd:anyURI ;
    linkml:base "str" ;
    linkml:definition_uri "https://w3id.org/linkml/Sparqlpath"^^xsd:anyURI ;
    linkml:description "A string encoding a SPARQL Property Path. The value of the string MUST conform to SPARQL syntax and SHOULD dereference to zero or more valid objects within the current instance document when encoded as RDF." ;
    linkml:imported_from "linkml:types" ;
    linkml:repr "str" ;
    linkml:uri "http://www.w3.org/2001/XMLSchema#string"^^xsd:anyURI .

<https://w3id.org/synapse/nfosi/vocab/spatial%20frequency%20domain%20imaging> dcterms:source "https://doi.org/10.3390/photonics8050162"^^xsd:anyURI ;
    skos:editorialNote "Note that term has no matches in OLS as of June 2022." ;
    linkml:description "Spatial Frequency Domain Imaging (SFDI) is a non-contact, depth-varying and wide-field optical imaging technique for measuring optical properties in a wide field-of-view on a pixel-by-pixel basis. Relevant applications include including burn assessment, skin tissue evaluation, tumor tissue detection, brain tissue monitoring." .

<https://w3id.org/synapse/nfosi/vocab/specimenCount> a linkml:SlotDefinition ;
    dcterms:title "Specimen Count" ;
    linkml:description "Number of unique specimens included in the dataset. Omit if not applicable/unknown." ;
    linkml:range <https://w3id.org/synapse/nfosi/vocab/integer> .

<https://w3id.org/synapse/nfosi/vocab/specimenIDSource> a linkml:SlotDefinition ;
    dcterms:title "Specimen ID Source" ;
    skos:inScheme "https://w3id.org/nfosi/"^^xsd:anyURI ;
    linkml:definition_uri "https://w3id.org/synapse/nfosi/vocab/specimenIDSource"^^xsd:anyURI ;
    linkml:description "Optional annotation describing where the specimen ID source derived from, e.g. the biobank providing samples or a providing lab." ;
    linkml:range <https://w3id.org/synapse/nfosi/vocab/string> ;
    linkml:slot_uri "https://w3id.org/synapse/nfosi/vocab/specimenIDSource"^^xsd:anyURI .

<https://w3id.org/synapse/nfosi/vocab/spheroid> dcterms:source "https://www.nature.com/articles/s41378-020-00185-3"^^xsd:anyURI ;
    linkml:description "Spheroids are 3D culture systems that can be used to model multicellular tumors; more broadly, spheroids can be defined as cell aggregates cultured on nonadherent substrates." .

<https://w3id.org/synapse/nfosi/vocab/spine> skos:altLabel "backbone",
        "columna vertebralis",
        "dorsal spine",
        "spinal column",
        "vertebral column skeleton",
        "vertebral region" ;
    linkml:description "" ;
    linkml:meaning "UBERON:0001130"^^xsd:anyURI .

<https://w3id.org/synapse/nfosi/vocab/spk> dcterms:source "https://ced.co.uk/"^^xsd:anyURI ;
    linkml:description "Spike2 data file format used by CED's data acquisition system for electrophysiology recordings." .

<https://w3id.org/synapse/nfosi/vocab/spleen> linkml:description "A highly vascular ductless organ that is located in the left abdominal region near the stomach or intestine of most vertebrates and is concerned with final destruction of red blood cells, filtration and storage of blood, and production of lymphocytes." ;
    linkml:meaning "BTO:0001281"^^xsd:anyURI .

<https://w3id.org/synapse/nfosi/vocab/splenocyte> linkml:description "Any leukocyte that is part of a spleen." ;
    linkml:meaning "BTO:0001598"^^xsd:anyURI .

<https://w3id.org/synapse/nfosi/vocab/split-GFP%20assay> linkml:description "An assay where complementary non-fluorescent fragments of GFP are fused to interacting proteins or brought into proximity; reconstitution of fluorescence indicates interaction or proximity." .

<https://w3id.org/synapse/nfosi/vocab/sqlite> linkml:description "Data format used by the SQLite database." ;
    linkml:meaning "EDAM:format_3621"^^xsd:anyURI .

<https://w3id.org/synapse/nfosi/vocab/sra> skos:altLabel "SRA archive format" ;
    linkml:description "SRA archive format (SRA) is the archive format used for input to the NCBI Sequence Read Archive." ;
    linkml:meaning "EDAM:format_3698"^^xsd:anyURI .

<https://w3id.org/synapse/nfosi/vocab/static%20histomorphometry> linkml:description "Static histomorphometry involves evaluation of bone parameters at a particular time point." .

<https://w3id.org/synapse/nfosi/vocab/static%20light%20scattering> skos:altLabel "DLSS",
        "TILS",
        "classical light scattering",
        "differential light-scattering spectroscopy",
        "differential static light scattering",
        "integrated light scattering",
        "static light scattering spectrometry",
        "static light scattering spectroscopy",
        "total intensity light scattering",
        "traditional light scattering" ;
    linkml:description "Static Light Scattering is a method for determining structure by measuring the total or time-averaged scattering intensity of scattered visible light as a function of angle." ;
    linkml:meaning "CHMO:0000180"^^xsd:anyURI .

<https://w3id.org/synapse/nfosi/vocab/stool> skos:altLabel "faeces",
        "fecal material",
        "fecal matter",
        "piece of shit",
        "portion of excrement",
        "portion of faeces",
        "portion of fecal material",
        "portionem cacas" ;
    linkml:description "Portion of semisolid bodily waste discharged through the anus." ;
    linkml:meaning "UBERON:0001988"^^xsd:anyURI .

<https://w3id.org/synapse/nfosi/vocab/structural%20variants> dcterms:source "https://w3id.org/synapse/nfosi/vocab/StructuralVariantss"^^xsd:anyURI ;
    linkml:description "Genomic variants data that covers deletions, duplications, CNVs, insertions, inversions, and translocations, which may be derived from specialized variant calling workflows." .

<https://w3id.org/synapse/nfosi/vocab/study> a linkml:SlotDefinition ;
    dcterms:title "Study" ;
    linkml:description "Study context: The study or project that this dataset belongs to" ;
    linkml:range <https://w3id.org/synapse/nfosi/vocab/string> ;
    linkml:required true .

<https://w3id.org/synapse/nfosi/vocab/subject> a linkml:SlotDefinition ;
    dcterms:title "Subject" ;
    linkml:description "Applicable subject term(s) for dataset cataloging; use the Library of Congress Subject Headings (LCSH) scheme." ;
    linkml:multivalued true ;
    linkml:range <https://w3id.org/synapse/nfosi/vocab/string> .

<https://w3id.org/synapse/nfosi/vocab/survey%20data> linkml:description "A data set that contains the outcome of a survey." ;
    linkml:meaning "OMIABIS:0000060"^^xsd:anyURI .

<https://w3id.org/synapse/nfosi/vocab/svg> skos:altLabel "Scalable Vector Graphics" ;
    linkml:description "Scalable Vector Graphics (SVG) is an XML-based vector image format for two-dimensional graphics with support for interactivity and animation." ;
    linkml:meaning "EDAM:format_3604"^^xsd:anyURI .

<https://w3id.org/synapse/nfosi/vocab/svs> dcterms:source "https://openslide.org/formats/aperio/"^^xsd:anyURI ;
    linkml:description "A single-file pyramidal tiled TIFF, with non-standard metadata and compression." .

<https://w3id.org/synapse/nfosi/vocab/sweat> skos:altLabel "skin exudate" ;
    linkml:description "Secretion produced by a sweat gland." ;
    linkml:meaning "UBERON:0001089"^^xsd:anyURI .

<https://w3id.org/synapse/nfosi/vocab/sws> dcterms:source "https://objectiveimaging.freshdesk.com/support/solutions/articles/9000076120-surveyor-image-formats"^^xsd:anyURI ;
    linkml:description "Surveyor Workspace format - a tiled microscopy image format from Objective Imaging systems comprising folders with high-resolution image tiles, thumbnails, metadata files, and a .sws file." .

<https://w3id.org/synapse/nfosi/vocab/synthetic> linkml:description "Data generated computationally via models or simulations, not direct experimental measurement." .

<https://w3id.org/synapse/nfosi/vocab/tagAlign> dcterms:source "https://genome.ucsc.edu/FAQ/FAQformat.html#format15"^^xsd:anyURI ;
    linkml:description "Tag Alignment provides genomic mapping of short sequence tags." .

<https://w3id.org/synapse/nfosi/vocab/tar> skos:altLabel "Tarball" ;
    linkml:description "TAR archive file format generated by the Unix-based utility tar." ;
    linkml:meaning "EDAM:format_3981"^^xsd:anyURI .

<https://w3id.org/synapse/nfosi/vocab/targeted%20exome%20sequencing> dcterms:source "https://labassure.com/whole-exome-sequencing-vs-clinical-exome-sequencing/"^^xsd:anyURI ;
    linkml:description "Also known as Clinical Exome Sequencing, Targeted Exome Sequencing is a subset of WES as it covers a limited number of genes, typically 3000 to 6000 genes." .

<https://w3id.org/synapse/nfosi/vocab/tbi> skos:altLabel "TBI Format",
        "Tabix" ;
    linkml:description "A TBI file is an index for a TABIX-compressed genomic data file, enabling rapid region-based retrieval." ;
    linkml:meaning "NCIT:C184806"^^xsd:anyURI .

<https://w3id.org/synapse/nfosi/vocab/teratoma> skos:altLabel "Teratoma, NOS",
        "Teratoma, Not Otherwise Specified" ;
    linkml:description "A non-seminomatous germ cell tumor characterized by the presence of various tissues which correspond to the different germinal layers (endoderm, mesoderm, and ectoderm). It occurs in the testis, ovary, and extragonadal sites including central nervous system, mediastinum, lung, and stomach" ;
    linkml:meaning "NCIT:C3403"^^xsd:anyURI .

<https://w3id.org/synapse/nfosi/vocab/text%20data> skos:altLabel "Article data",
        "Scientific text data",
        "space-delimited text" ;
    linkml:description "Data that is represented as text, usually referring to \"unstructured data\"." ;
    linkml:meaning "EDAM:data_2526"^^xsd:anyURI .

<https://w3id.org/synapse/nfosi/vocab/thoracic%20spine> skos:altLabel "axial skeleton thoracic region",
        "columna vertebralis thoracicus",
        "thoracic vertebrae series",
        "thoracic vertebral column" ;
    linkml:description "" ;
    linkml:meaning "UBERON:0006073"^^xsd:anyURI .

<https://w3id.org/synapse/nfosi/vocab/thymus> linkml:description "A glandular structure of largely lymphoid tissue that functions especially in the development of the body's immune system, is present in the young of most vertebrates typically in the upper anterior chest or at the base of the neck, and tends to atrophy in the adult." ;
    linkml:meaning "BTO:0001374"^^xsd:anyURI .

<https://w3id.org/synapse/nfosi/vocab/tif> linkml:description "Tagged Image File Format, abbreviated TIFF or TIF, is a computer file format for storing raster graphics images" ;
    linkml:meaning "EDAM:format_3591"^^xsd:anyURI .

<https://w3id.org/synapse/nfosi/vocab/time> a linkml:TypeDefinition ;
    skos:editorialNote "If you are authoring schemas in LinkML YAML, the type is referenced with the lower case \"time\".",
        "URI is dateTime because OWL reasoners do not work with straight date or time" ;
    skos:exactMatch "schema:Time"^^xsd:anyURI ;
    skos:inScheme "https://w3id.org/linkml/types"^^xsd:anyURI ;
    linkml:base "XSDTime" ;
    linkml:definition_uri "https://w3id.org/linkml/Time"^^xsd:anyURI ;
    linkml:description "A time object represents a (local) time of day, independent of any particular day" ;
    linkml:imported_from "linkml:types" ;
    linkml:repr "str" ;
    linkml:uri "http://www.w3.org/2001/XMLSchema#time"^^xsd:anyURI .

<https://w3id.org/synapse/nfosi/vocab/tom> dcterms:source "http://canfieldupgrade.com/assets/media/VECTRA-M3-User-Guide.pdf"^^xsd:anyURI ;
    skos:editorialNote "No other model has this as it is relatively new and highly specific format for a proprietary platform." ;
    linkml:description "The .tom format is a specialized 3D image export format from the Vectra medical imaging systems that can optionally preserve trimmings and/or landmarks." .

<https://w3id.org/synapse/nfosi/vocab/tonsil> skos:altLabel "Mandel" ;
    linkml:description "The human palatine tonsils and the nasopharyngeal tonsil are lymphoepithelial tissues located in strategic areas of the oropharynx and nasopharynx, although most commonly, the term tonsils refers to the palatine tonsils that can be seen in the back of the throat." ;
    linkml:meaning "BTO:0001387"^^xsd:anyURI .

<https://w3id.org/synapse/nfosi/vocab/tool> dcterms:source "https://synapse.org"^^xsd:anyURI ;
    linkml:description "Any file or link that represents a tool, model, or algorithm; the tool annotations could be applied" .

<https://w3id.org/synapse/nfosi/vocab/traction%20force%20microscopy> dcterms:source "https://en.wikipedia.org/wiki/Traction_force_microscopy"^^xsd:anyURI ;
    linkml:description "An experimental method for determining the tractions on the surface of a biological cell by obtaining measurements of the surrounding displacement field within an in vitro extracellular matrix (ECM)" .

<https://w3id.org/synapse/nfosi/vocab/tranches> dcterms:source "https://software.broadinstitute.org/gatk/documentation/tooldocs/3.8-0/org_broadinstitute_gatk_tools_walkers_variantrecalibration_VariantRecalibrator.php#--tranches_file"^^xsd:anyURI ;
    linkml:description ".tranches file from GATK VQSR" .

<https://w3id.org/synapse/nfosi/vocab/trans-endothelial%20electrical%20resistance> linkml:description "Trans-endothelial electrical resistance (TEER), aka epithelial voltohmmeter (EVOM) assay, is used to assess the integrity and barrier function of epithelial cell monolayers in cell culture experiments." ;
    linkml:meaning "ENM:8000301"^^xsd:anyURI .

<https://w3id.org/synapse/nfosi/vocab/transcranial%20doppler%20ultrasonography> skos:altLabel "Non-imaging TCD",
        "TCD",
        "Transcranial Doppler",
        "Transcranial Doppler Ultrasound" ;
    linkml:description "A diagnostic technique that uses pulsed Doppler ultrasound to measure the velocity of blood flow through the major blood vessels of the brain." ;
    linkml:meaning "NCIT:C122930"^^xsd:anyURI .

<https://w3id.org/synapse/nfosi/vocab/tsv> skos:altLabel "Tab-delimited",
        "Tab-separated values",
        "tab" ;
    linkml:description "Tabular data represented as tab-separated values in a text file" ;
    linkml:meaning "EDAM:format_3475"^^xsd:anyURI .

<https://w3id.org/synapse/nfosi/vocab/tumor> skos:altLabel "TUMOR TISSUE",
        "Tumor Sample",
        "Tumor Tissue Sample" ;
    linkml:description "General term for tumor sample – use when it is unknown when a more specific clinical classification is unknown, e.g. whether it is primary or secondary." ;
    linkml:meaning "NCIT:C18009"^^xsd:anyURI .

<https://w3id.org/synapse/nfosi/vocab/tumor-adjacent%20normal> skos:altLabel "Peritumoral",
        "Tumor-Adjacent Normal Sample",
        "Tumor-Adjacent Normal Specimen" ;
    linkml:description "Tissue comprised of morphologically normal tissue collected from the area immediately surrounding a tumor." ;
    linkml:meaning "NCIT:C164032"^^xsd:anyURI .

<https://w3id.org/synapse/nfosi/vocab/twin%20spot%20assay> dcterms:source "https://pubmed.ncbi.nlm.nih.gov/29378809/"^^xsd:anyURI ;
    linkml:description "Two individual and genetically different populations of cells that originate from the same mitotic recombination event; twin spots allow a direct and reliable comparison between mutant and wild-type clones, and the size of the wild-type twin can serve as a reference for comparison with the homozygous mutant clones." .

<https://w3id.org/synapse/nfosi/vocab/txt> skos:altLabel "Plain text format" ;
    linkml:description "Plain text file, commonly used for tab- or space-delimited count matrices in bioinformatics workflows." ;
    linkml:meaning "EDAM:format_2330"^^xsd:anyURI .

<https://w3id.org/synapse/nfosi/vocab/type> a linkml:SlotDefinition ;
    dcterms:title "Type" ;
    skos:inScheme "https://w3id.org/nfosi/"^^xsd:anyURI ;
    linkml:definition_uri "https://w3id.org/synapse/nfosi/vocab/type"^^xsd:anyURI ;
    linkml:description "Refers to the type of the resource on the platform, e.g. “file”." ;
    linkml:range <https://w3id.org/synapse/nfosi/vocab/string> ;
    linkml:slot_uri "https://w3id.org/synapse/nfosi/vocab/type"^^xsd:anyURI .

<https://w3id.org/synapse/nfosi/vocab/ultra%20high-performance%20liquid%20chromatography/tandem%20mass%20spectrometry> skos:altLabel "U-HPLC/MS/MS" ;
    linkml:description "UPLC-MSMS is an analytical technique wherein ultra-high performance liquid chromatography is coupled to tandem mass spectrometry in order to separate, identify, and quantify substances in a sample." ;
    linkml:meaning "NCIT:C122176"^^xsd:anyURI .

<https://w3id.org/synapse/nfosi/vocab/uri> a linkml:TypeDefinition ;
    dcterms:conformsTo "https://www.ietf.org/rfc/rfc3987.txt" ;
    skos:closeMatch "schema:URL"^^xsd:anyURI ;
    skos:editorialNote "If you are authoring schemas in LinkML YAML, the type is referenced with the lower case \"uri\"." ;
    skos:inScheme "https://w3id.org/linkml/types"^^xsd:anyURI ;
    skos:note "in RDF serializations a slot with range of uri is treated as a literal or type xsd:anyURI unless it is an identifier or a reference to an identifier, in which case it is translated directly to a node" ;
    linkml:base "URI" ;
    linkml:definition_uri "https://w3id.org/linkml/Uri"^^xsd:anyURI ;
    linkml:description "a complete URI" ;
    linkml:imported_from "linkml:types" ;
