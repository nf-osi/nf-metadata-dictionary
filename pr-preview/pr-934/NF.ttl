<https://w3id.org/synapse/nfosi/vocab/Vestibular%20Schwannoma> dcterms:source "https://oncotree.mskcc.org/?version=oncotree_latest_stable&field=SCHW"^^xsd:anyURI ;
    skos:altLabel "Acoustic Neurilemmoma",
        "Acoustic Neuroma",
        "Acoustic Schwannoma",
        "Neurilemoma, Acoustic",
        "Neuroma, Acoustic",
        "Vestibular Neurilemmoma" ;
    linkml:description "A schwannoma arising from the vestibular branch of the eighth cranial nerve (vestibulocochlear nerve). The most common tumor in NF2-related schwannomatosis. Can occur sporadically (unilateral) or bilaterally in NF2." ;
    linkml:meaning "NCIT:C3276"^^xsd:anyURI .

