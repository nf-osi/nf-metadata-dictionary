<https://w3id.org/synapse/nfosi/vocab/dataType> a linkml:SlotDefinition ;
    dcterms:title "Data Type",
        "Type" ;
    skos:inScheme "https://w3id.org/nfosi/"^^xsd:anyURI ;
    linkml:any_of [ a linkml:AnonymousSlotExpression ;
            linkml:range <https://w3id.org/synapse/nfosi/vocab/MetadataEnum> ],
        [ a linkml:AnonymousSlotExpression ;
            linkml:range <https://w3id.org/synapse/nfosi/vocab/Data> ],
        [ a linkml:AnonymousSlotExpression ;
            linkml:range <https://w3id.org/synapse/nfosi/vocab/UnknownEnum> ],
        [ a linkml:AnonymousSlotExpression ;
            linkml:range <https://w3id.org/synapse/nfosi/vocab/Data> ] ;
    linkml:definition_uri "https://w3id.org/synapse/nfosi/vocab/dataType"^^xsd:anyURI ;
    linkml:description """Links an entity to data types that the entity represents/contains. This is closely tied to the assay property. For example, a file of dataType `genomicVariants` might have an assay value of `whole genome sequencing`.
""",
        "Reflects the data types within the dataset.",
        "Scientific characteristics: The type of data that will be uploaded in this dataset. If you are unsure or cannot find the appropriate term, please use 'Unknown' and email nf-osi@sagebase.org for help." ;
    linkml:domain_of <https://w3id.org/synapse/nfosi/vocab/AnalysisResultTemplate>,
        <https://w3id.org/synapse/nfosi/vocab/BiologicalAssayDataTemplate>,
        <https://w3id.org/synapse/nfosi/vocab/EpidemiologyDataTemplate>,
        <https://w3id.org/synapse/nfosi/vocab/GenericDataResourceTemplate>,
        <https://w3id.org/synapse/nfosi/vocab/NonBiologicalAssayDataTemplate>,
        <https://w3id.org/synapse/nfosi/vocab/ProcessedAggregatedDataTemplate>,
        <https://w3id.org/synapse/nfosi/vocab/ProcessedMergedDataTemplate>,
        <https://w3id.org/synapse/nfosi/vocab/ReferenceSequenceTemplate> ;
    linkml:multivalued true ;
    linkml:owner <https://w3id.org/synapse/nfosi/vocab/AnalysisResultTemplate> ;
    linkml:range <https://w3id.org/synapse/nfosi/vocab/Data>,
        <https://w3id.org/synapse/nfosi/vocab/string> ;
    linkml:required true ;
    linkml:slot_uri "https://w3id.org/synapse/nfosi/vocab/dataType"^^xsd:anyURI ;
    linkml:value_presence [ a linkml:PermissibleValue ;
            skos:notation "PRESENT" ],
        [ a linkml:PermissibleValue ;
            skos:notation "PRESENT" ],
        [ a linkml:PermissibleValue ;
            skos:notation "PRESENT" ],
        [ a linkml:PermissibleValue ;
            skos:notation "PRESENT" ],
        [ a linkml:PermissibleValue ;
            skos:notation "PRESENT" ],
        [ a linkml:PermissibleValue ;
            skos:notation "PRESENT" ],
        [ a linkml:PermissibleValue ;
            skos:notation "PRESENT" ],
        [ a linkml:PermissibleValue ;
            skos:notation "PRESENT" ],
        [ a linkml:PermissibleValue ;
            skos:notation "PRESENT" ],
        [ a linkml:PermissibleValue ;
            skos:notation "PRESENT" ],
        [ a linkml:PermissibleValue ;
            skos:notation "PRESENT" ] .

<https://w3id.org/synapse/nfosi/vocab/AnalysisResultTemplate> a linkml:ClassDefinition ;
    skos:inScheme "https://w3id.org/nfosi/"^^xsd:anyURI ;
    sh:rule [ a linkml:ClassRule ;
            sh:condition [ a linkml:AnonymousClassExpression ;
                    linkml:slot_conditions <https://w3id.org/synapse/nfosi/vocab/dataType> ] ;
            linkml:description "If dataType is provided, dataSubtype must be provided" ;
            linkml:postconditions [ a linkml:AnonymousClassExpression ;
                    linkml:slot_conditions <https://w3id.org/synapse/nfosi/vocab/dataSubtype> ] ],
        [ a linkml:ClassRule ;
            sh:condition [ a linkml:AnonymousClassExpression ;
                    linkml:slot_conditions <https://w3id.org/synapse/nfosi/vocab/resourceType> ] ;
            linkml:description "Relaxed conditional validation (issue #825): the listed fields are required only for experimentalData. Auxiliary co-located files (manifest, metadata, report, workflow report, tool, result, weblink, protocol) are exempt." ;
            linkml:postconditions [ a linkml:AnonymousClassExpression ;
                    linkml:slot_conditions <https://w3id.org/synapse/nfosi/vocab/dataSubtype>,
                        <https://w3id.org/synapse/nfosi/vocab/dataType> ] ] ;
    linkml:class_uri "https://w3id.org/synapse/nfosi/vocab/AnalysisResultTemplate"^^xsd:anyURI ;
    linkml:definition_uri "https://w3id.org/synapse/nfosi/vocab/AnalysisResultTemplate"^^xsd:anyURI ;
    linkml:description "Template for result files such as figures, presentations, and analysis outputs that report data results but are not primary experimental data." ;
    linkml:is_a <https://w3id.org/synapse/nfosi/vocab/FileBasedTemplate> ;
    linkml:slot_usage [ ] ;
    linkml:slots <https://w3id.org/synapse/nfosi/vocab/AnalysisResultTemplate_dataSubtype>,
        <https://w3id.org/synapse/nfosi/vocab/AnalysisResultTemplate_dataType>,
        <https://w3id.org/synapse/nfosi/vocab/AnalysisResultTemplate_fileFormat>,
