<https://w3id.org/synapse/nfosi/vocab/portalDataset__doi> a linkml:SlotDefinition ;
    dcterms:title "doi" ;
    skos:inScheme "https://w3id.org/nfosi/"^^xsd:anyURI ;
    skos:prefLabel "doi" ;
    linkml:description "The Digital Object Identifier (DOI) of the dataset (if one has been created), used for citation and persistent identification." ;
    linkml:domain_of <https://w3id.org/synapse/nfosi/vocab/PortalDataset> ;
    linkml:owner <https://w3id.org/synapse/nfosi/vocab/PortalDataset> ;
    linkml:pattern "^10\\\\.\\\\d{4,9}/[-._;()/:A-Z0-9]+$" ;
    linkml:range <https://w3id.org/synapse/nfosi/vocab/string> ;
    linkml:slot_uri "https://w3id.org/synapse/nfosi/vocab/doi"^^xsd:anyURI .

