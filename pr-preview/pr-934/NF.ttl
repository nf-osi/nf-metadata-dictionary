<https://w3id.org/synapse/nfosi/vocab/dup> dcterms:source "https://software.broadinstitute.org/gatk/documentation/tooldocs/4.0.4.0/picard_sam_markduplicates_MarkDuplicates.php"^^xsd:anyURI ;
    linkml:description "output of the Picard MarkDuplicates tool." .

<https://w3id.org/synapse/nfosi/vocab/dynamic%20light%20scattering> skos:altLabel "DLS",
        "PCS",
        "QELS",
        "dynamic laser scattering",
        "dynamic light scattering spectrometry",
        "dynamic light scattering spectroscopy",
        "photon correlation spectrometry",
        "photon correlation spectroscopy",
        "quasi-elastic light scattering",
        "quasi-elastic light scattering spectrometry",
        "quasi-elastic light scattering spectroscopy" ;
    linkml:description "Dynamic Light Scattering (DLS), also known as photocorrelation spectroscopy, is a method for determining the size distribution of a sample of small particles in solution by illuminating the sample with a light source (usually a laser) and measuring the time-dependent fluctuations in the intensity of the scattered light caused by Brownian motion." ;
    linkml:meaning "CHMO:0000167"^^xsd:anyURI .

<https://w3id.org/synapse/nfosi/vocab/edat3> dcterms:source "https://support.pstnet.com/hc/en-us/articles/229354727-INFO-E-Prime-file-extensions-18091"^^xsd:anyURI ;
    linkml:description "The .edat3 proprietary format is used to store experiment data that can be analyzed in E-DataAid." .

<https://w3id.org/synapse/nfosi/vocab/electrochemiluminescence> dcterms:source "https://www.mesoscale.com/en/technical_resources/our_technology/ecl"^^xsd:anyURI ;
    linkml:description "A method in which electromagnetic radiation, in the form of light emission, is generated from an electrochemical reaction in a solution." ;
    linkml:meaning "NCIT:C111193"^^xsd:anyURI .

<https://w3id.org/synapse/nfosi/vocab/electrophoretic%20light%20scattering> dcterms:source "https://en.wikipedia.org/wiki/Electrophoretic_light_scattering"^^xsd:anyURI ;
    linkml:description "Subtype of dynamic light scattering, used to measure electrophoretic mobility." .

<https://w3id.org/synapse/nfosi/vocab/electrophysiology> dcterms:source "https://bioportal.bioontology.org/ontologies/ERO/?p=classes&conceptid=http%3A%2F%2Fpurl.obolibrary.org%2Fobo%2FERO_0000564&jump_to_nav=true"^^xsd:anyURI ;
    skos:editorialNote "ERO has been deprecated and direct URIs no longer work." ;
    linkml:description """Data generated from an electrophysiology assay, e.g: 
- Cell: Resting membrane potential, ion channel currents (patch clamp data)
- Neurons: Action potentials, resting potential, synaptic potentials. 
- Heart: Electrocardiogram (ECG/EKG) waveforms, cardiac action potentials.
- Muscle: Electromyogram (EMG) signals
- Whole brain: Electroencephalogram (EEG)
- Retina: Electroretinogram (ERG)
""" .

<https://w3id.org/synapse/nfosi/vocab/elevated%20plus%20maze%20test> skos:altLabel "EPM apparatus method",
        "EPM test" ;
    linkml:description "A method which utilizes an experimental apparatus consisting of four arms, usually two enclosed and two open, in the shape of a plus (+) upon which the test animal can walk. The maze is elevated a set distance, for example 40 to 60 centimeters, above the floor or platform upon which the apparatus sits." ;
    linkml:meaning "MMO:0000262"^^xsd:anyURI .

