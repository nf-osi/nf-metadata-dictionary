<https://w3id.org/synapse/nfosi/vocab/NonBiologicalAssayDataTemplate> a linkml:ClassDefinition ;
    skos:editorialNote "Name of this base abstraction is not great, may need to revise." ;
    skos:inScheme "https://w3id.org/nfosi/"^^xsd:anyURI ;
    sh:rule [ a linkml:ClassRule ;
            sh:condition [ a linkml:AnonymousClassExpression ;
                    linkml:slot_conditions <https://w3id.org/synapse/nfosi/vocab/resourceType> ] ;
            linkml:description "Relaxed conditional validation (issue #825): the listed fields are required only for experimentalData. Auxiliary co-located files (manifest, metadata, report, workflow report, tool, result, weblink, protocol) are exempt." ;
            linkml:postconditions [ a linkml:AnonymousClassExpression ;
                    linkml:slot_conditions <https://w3id.org/synapse/nfosi/vocab/assay>,
                        <https://w3id.org/synapse/nfosi/vocab/dataSubtype>,
                        <https://w3id.org/synapse/nfosi/vocab/dataType> ] ] ;
    linkml:abstract true ;
    linkml:class_uri "https://w3id.org/synapse/nfosi/vocab/NonBiologicalAssayDataTemplate"^^xsd:anyURI ;
    linkml:definition_uri "https://w3id.org/synapse/nfosi/vocab/NonBiologicalAssayDataTemplate"^^xsd:anyURI ;
    linkml:description """Describes data artifacts (i.e. files) from an experimental/physical-sciences assay  where input specimens are more at the level of synthesized molecules or inorganic materials.
""" ;
    linkml:is_a <https://w3id.org/synapse/nfosi/vocab/FileBasedTemplate> ;
    linkml:slot_usage [ ] ;
    linkml:slots <https://w3id.org/synapse/nfosi/vocab/Component>,
