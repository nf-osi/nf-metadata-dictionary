<https://w3id.org/synapse/nfosi/vocab/auxiliaryAsset> a linkml:SlotDefinition ;
    dcterms:title "Auxiliary Asset" ;
    skos:inScheme "https://w3id.org/nfosi/"^^xsd:anyURI ;
    linkml:definition_uri "https://w3id.org/synapse/nfosi/vocab/auxiliaryAsset"^^xsd:anyURI ;
    linkml:description """URI to supplemental asset(s), e.g. QC reports or other auxiliary files to support the processing, analysis, or interpretation of the current entity.
""" ;
    linkml:domain_of <https://w3id.org/synapse/nfosi/vocab/ElectrophysiologyAssayTemplate>,
        <https://w3id.org/synapse/nfosi/vocab/FlowCytometryTemplate>,
        <https://w3id.org/synapse/nfosi/vocab/ImagingAssayTemplate>,
        <https://w3id.org/synapse/nfosi/vocab/ProcessedAggregatedDataTemplate>,
        <https://w3id.org/synapse/nfosi/vocab/ProcessedAlignedReadsTemplate>,
        <https://w3id.org/synapse/nfosi/vocab/ProcessedGeneExpressionTemplate>,
        <https://w3id.org/synapse/nfosi/vocab/ProcessedMergedDataTemplate>,
        <https://w3id.org/synapse/nfosi/vocab/ProcessedVariantCallsTemplate>,
        <https://w3id.org/synapse/nfosi/vocab/ScSequencingAssayTemplate> ;
    linkml:owner <https://w3id.org/synapse/nfosi/vocab/ImagingAssayTemplate> ;
    linkml:range <https://w3id.org/synapse/nfosi/vocab/string> ;
    linkml:slot_uri "https://w3id.org/synapse/nfosi/vocab/auxiliaryAsset"^^xsd:anyURI .

<https://w3id.org/synapse/nfosi/vocab/modelSystemName> a linkml:SlotDefinition ;
    dcterms:title "Model System Name" ;
    skos:inScheme "https://w3id.org/nfosi/"^^xsd:anyURI ;
    linkml:any_of [ a linkml:AnonymousSlotExpression ;
            linkml:range <https://w3id.org/synapse/nfosi/vocab/CellLineModelManual> ],
        [ a linkml:AnonymousSlotExpression ;
            linkml:range <https://w3id.org/synapse/nfosi/vocab/CellLineModel> ],
        [ a linkml:AnonymousSlotExpression ;
            linkml:range <https://w3id.org/synapse/nfosi/vocab/AnimalModel> ],
        [ a linkml:AnonymousSlotExpression ;
            linkml:range <https://w3id.org/synapse/nfosi/vocab/AnimalModelManual> ] ;
    linkml:definition_uri "https://w3id.org/synapse/nfosi/vocab/modelSystemName"^^xsd:anyURI ;
    linkml:description "A group of presumed common ancestry with clear-cut physiological but usually not morphological distinctions such as an animal model or cell line. EXAMPLE(S):  HEK293 (cell line), Minnesota5 (swine strain), DXL (poultry strain), RB51 (vaccine strain of Brucella abortus)" ;
    linkml:domain_of <https://w3id.org/synapse/nfosi/vocab/AnimalIndividualTemplate>,
        <https://w3id.org/synapse/nfosi/vocab/BehavioralAssayTemplate>,
        <https://w3id.org/synapse/nfosi/vocab/BiospecimenTemplate>,
        <https://w3id.org/synapse/nfosi/vocab/BulkSequencingAssayTemplate>,
        <https://w3id.org/synapse/nfosi/vocab/CellTissuePhenotypingTemplate>,
        <https://w3id.org/synapse/nfosi/vocab/PdxGenomicsAssayTemplate> ;
    linkml:multivalued true ;
    linkml:owner <https://w3id.org/synapse/nfosi/vocab/PdxGenomicsAssayTemplate> ;
    linkml:range <https://w3id.org/synapse/nfosi/vocab/string> ;
    linkml:slot_uri "https://w3id.org/synapse/nfosi/vocab/modelSystemName"^^xsd:anyURI .

<https://w3id.org/synapse/nfosi/vocab/AnimalIndividualTemplate> a linkml:ClassDefinition ;
    skos:inScheme "https://w3id.org/nfosi/"^^xsd:anyURI ;
    linkml:class_uri "https://w3id.org/synapse/nfosi/vocab/AnimalIndividualTemplate"^^xsd:anyURI ;
    linkml:definition_uri "https://w3id.org/synapse/nfosi/vocab/AnimalIndividualTemplate"^^xsd:anyURI ;
    linkml:description "Template for non-human individual-level data. Use sex/age/species for the individual animal, and modelSystemName for the name of the mouse model." ;
    linkml:slot_usage [ ] ;
    linkml:slots <https://w3id.org/synapse/nfosi/vocab/age>,
        <https://w3id.org/synapse/nfosi/vocab/ageUnit>,
        <https://w3id.org/synapse/nfosi/vocab/diagnosis>,
        <https://w3id.org/synapse/nfosi/vocab/diagnosisAgeGroup>,
        <https://w3id.org/synapse/nfosi/vocab/germlineMutation>,
        <https://w3id.org/synapse/nfosi/vocab/individualID>,
        <https://w3id.org/synapse/nfosi/vocab/inheritance>,
        <https://w3id.org/synapse/nfosi/vocab/modelSystemName>,
        <https://w3id.org/synapse/nfosi/vocab/mosaicism>,
        <https://w3id.org/synapse/nfosi/vocab/nf1Genotype>,
        <https://w3id.org/synapse/nfosi/vocab/nf2Genotype>,
        <https://w3id.org/synapse/nfosi/vocab/sex>,
        <https://w3id.org/synapse/nfosi/vocab/species> .

<https://w3id.org/synapse/nfosi/vocab/ProcessedGeneExpressionTemplate> a linkml:ClassDefinition ;
    skos:closeMatch "htan:BulkRNA-seqLevel3"^^xsd:anyURI ;
    skos:inScheme "https://w3id.org/nfosi/"^^xsd:anyURI ;
    sh:rule [ a linkml:ClassRule ;
            sh:condition [ a linkml:AnonymousClassExpression ;
                    linkml:slot_conditions <https://w3id.org/synapse/nfosi/vocab/workflow> ] ;
            linkml:description "If workflow is provided, workflowLink must be provided" ;
            linkml:postconditions [ a linkml:AnonymousClassExpression ;
                    linkml:slot_conditions <https://w3id.org/synapse/nfosi/vocab/workflowLink> ] ],
        [ a linkml:ClassRule ;
            sh:condition [ a linkml:AnonymousClassExpression ;
                    linkml:slot_conditions <https://w3id.org/synapse/nfosi/vocab/resourceType> ] ;
            linkml:description "Relaxed conditional validation (issue #825): the listed fields are required only for experimentalData. Auxiliary co-located files (manifest, metadata, report, workflow report, tool, result, weblink, protocol) are exempt." ;
            linkml:postconditions [ a linkml:AnonymousClassExpression ;
                    linkml:slot_conditions <https://w3id.org/synapse/nfosi/vocab/expressionUnit>,
                        <https://w3id.org/synapse/nfosi/vocab/specimenID> ] ] ;
    linkml:class_uri "https://w3id.org/synapse/nfosi/vocab/ProcessedGeneExpressionTemplate"^^xsd:anyURI ;
    linkml:definition_uri "https://w3id.org/synapse/nfosi/vocab/ProcessedGeneExpressionTemplate"^^xsd:anyURI ;
    linkml:description "Template for quantified gene/protein expression data that are still represented as one file per sample." ;
    linkml:is_a <https://w3id.org/synapse/nfosi/vocab/BiologicalAssayDataTemplate> ;
    linkml:slot_usage [ ] ;
    linkml:slots <https://w3id.org/synapse/nfosi/vocab/BiologicalAssayDataTemplate_assay>,
        <https://w3id.org/synapse/nfosi/vocab/BiologicalAssayDataTemplate_dataType>,
        <https://w3id.org/synapse/nfosi/vocab/BiologicalAssayDataTemplate_diagnosis>,
        <https://w3id.org/synapse/nfosi/vocab/BiologicalAssayDataTemplate_individualID>,
        <https://w3id.org/synapse/nfosi/vocab/BiologicalAssayDataTemplate_species>,
        <https://w3id.org/synapse/nfosi/vocab/BiologicalAssayDataTemplate_tumorType>,
        <https://w3id.org/synapse/nfosi/vocab/Component>,
        <https://w3id.org/synapse/nfosi/vocab/Filename>,
        <https://w3id.org/synapse/nfosi/vocab/ProcessedGeneExpressionTemplate_dataSubtype>,
        <https://w3id.org/synapse/nfosi/vocab/ProcessedGeneExpressionTemplate_expressionUnit>,
        <https://w3id.org/synapse/nfosi/vocab/ProcessedGeneExpressionTemplate_specimenID>,
        <https://w3id.org/synapse/nfosi/vocab/age>,
        <https://w3id.org/synapse/nfosi/vocab/ageUnit>,
        <https://w3id.org/synapse/nfosi/vocab/antibodyID>,
        <https://w3id.org/synapse/nfosi/vocab/auxiliaryAsset>,
        <https://w3id.org/synapse/nfosi/vocab/comments>,
        <https://w3id.org/synapse/nfosi/vocab/fileFormat>,
        <https://w3id.org/synapse/nfosi/vocab/geneticReagentID>,
        <https://w3id.org/synapse/nfosi/vocab/nf1Genotype>,
        <https://w3id.org/synapse/nfosi/vocab/nf2Genotype>,
        <https://w3id.org/synapse/nfosi/vocab/organ>,
        <https://w3id.org/synapse/nfosi/vocab/resourceType>,
        <https://w3id.org/synapse/nfosi/vocab/sex>,
        <https://w3id.org/synapse/nfosi/vocab/workflow>,
        <https://w3id.org/synapse/nfosi/vocab/workflowLink> .

<https://w3id.org/synapse/nfosi/vocab/WorkflowReport> a linkml:ClassDefinition ;
    skos:editorialNote "note that `dataType` and `dataSubtype` don't apply",
        "resourceType should default to \"workflow report\"" ;
    skos:inScheme "https://w3id.org/nfosi/"^^xsd:anyURI ;
    sh:rule [ a linkml:ClassRule ;
            sh:condition [ a linkml:AnonymousClassExpression ;
                    linkml:slot_conditions <https://w3id.org/synapse/nfosi/vocab/workflow> ] ;
            linkml:description "If workflow is provided, workflowLink must be provided" ;
            linkml:postconditions [ a linkml:AnonymousClassExpression ;
                    linkml:slot_conditions <https://w3id.org/synapse/nfosi/vocab/workflowLink> ] ],
        [ a linkml:ClassRule ;
            sh:condition [ a linkml:AnonymousClassExpression ;
                    linkml:slot_conditions <https://w3id.org/synapse/nfosi/vocab/resourceType> ] ;
            linkml:description "Relaxed conditional validation (issue #825): the listed fields are required only for experimentalData. Auxiliary co-located files (manifest, metadata, report, workflow report, tool, result, weblink, protocol) are exempt." ;
            linkml:postconditions [ a linkml:AnonymousClassExpression ;
                    linkml:slot_conditions <https://w3id.org/synapse/nfosi/vocab/assay> ] ] ;
    linkml:class_uri "https://w3id.org/synapse/nfosi/vocab/WorkflowReport"^^xsd:anyURI ;
    linkml:definition_uri "https://w3id.org/synapse/nfosi/vocab/WorkflowReport"^^xsd:anyURI ;
    linkml:description "Template used for miscellaneous workflow reports and accessory files" ;
    linkml:is_a <https://w3id.org/synapse/nfosi/vocab/FileBasedTemplate> ;
    linkml:slot_usage [ ] ;
    linkml:slots <https://w3id.org/synapse/nfosi/vocab/Component>,
        <https://w3id.org/synapse/nfosi/vocab/Filename>,
        <https://w3id.org/synapse/nfosi/vocab/WorkflowReport_assay>,
        <https://w3id.org/synapse/nfosi/vocab/WorkflowReport_resourceType>,
        <https://w3id.org/synapse/nfosi/vocab/fileFormat>,
        <https://w3id.org/synapse/nfosi/vocab/relatedDataset>,
        <https://w3id.org/synapse/nfosi/vocab/workflow>,
        <https://w3id.org/synapse/nfosi/vocab/workflowLink> .

<https://w3id.org/synapse/nfosi/vocab/experimentalTimepoint> a linkml:SlotDefinition ;
    dcterms:title "Experimental Timepoint" ;
    skos:inScheme "https://w3id.org/nfosi/"^^xsd:anyURI ;
    linkml:definition_uri "https://w3id.org/synapse/nfosi/vocab/experimentalTimepoint"^^xsd:anyURI ;
    linkml:description "The numeric value indicating the time elapsed from the beginning of the experiment at which the specimen was collected. Use in tandem with timePointUnit" ;
    linkml:domain_of <https://w3id.org/synapse/nfosi/vocab/BehavioralAssayTemplate>,
        <https://w3id.org/synapse/nfosi/vocab/CellTissuePhenotypingTemplate>,
        <https://w3id.org/synapse/nfosi/vocab/ElectrophysiologyAssayTemplate>,
        <https://w3id.org/synapse/nfosi/vocab/GenomicsAssayTemplateExtended>,
        <https://w3id.org/synapse/nfosi/vocab/MRIAssayTemplate>,
        <https://w3id.org/synapse/nfosi/vocab/PdxGenomicsAssayTemplate>,
        <https://w3id.org/synapse/nfosi/vocab/PlateBasedReporterAssayTemplate> ;
    linkml:owner <https://w3id.org/synapse/nfosi/vocab/MRIAssayTemplate> ;
    linkml:range <https://w3id.org/synapse/nfosi/vocab/float> ;
    linkml:slot_uri "https://w3id.org/synapse/nfosi/vocab/experimentalTimepoint"^^xsd:anyURI ;
    linkml:value_presence [ a linkml:PermissibleValue ;
            skos:notation "PRESENT" ],
        [ a linkml:PermissibleValue ;
            skos:notation "PRESENT" ],
        [ a linkml:PermissibleValue ;
            skos:notation "PRESENT" ],
        [ a linkml:PermissibleValue ;
            skos:notation "PRESENT" ],
        [ a linkml:PermissibleValue ;
            skos:notation "PRESENT" ],
        [ a linkml:PermissibleValue ;
            skos:notation "PRESENT" ],
        [ a linkml:PermissibleValue ;
            skos:notation "PRESENT" ] .

<https://w3id.org/synapse/nfosi/vocab/unknown> linkml:description "Library kit information not provided or not available",
        "Target capture kit information not provided or not available",
        "information not provided" .

<https://w3id.org/synapse/nfosi/vocab/FileBasedTemplate> a linkml:ClassDefinition ;
    skos:editorialNote "FileBasedTemplate and RecordBasedTemplate are not technically mutually exclusive; some resources may have both file and record representations." ;
    skos:inScheme "https://w3id.org/nfosi/"^^xsd:anyURI ;
    linkml:abstract true ;
    linkml:class_uri "https://w3id.org/synapse/nfosi/vocab/FileBasedTemplate"^^xsd:anyURI ;
    linkml:definition_uri "https://w3id.org/synapse/nfosi/vocab/FileBasedTemplate"^^xsd:anyURI ;
    linkml:description "Abstract template for metadata on file-based resources, i.e. data artifacts stored as files." ;
    linkml:is_a <https://w3id.org/synapse/nfosi/vocab/Template> ;
    linkml:slot_usage [ ] ;
    linkml:slots <https://w3id.org/synapse/nfosi/vocab/Component>,
        <https://w3id.org/synapse/nfosi/vocab/Filename>,
        <https://w3id.org/synapse/nfosi/vocab/fileFormat>,
        <https://w3id.org/synapse/nfosi/vocab/resourceType> .

<https://w3id.org/synapse/nfosi/vocab/GeneticsAssayTemplate_specimenID> a linkml:SlotDefinition ;
    dcterms:title "Specimen ID" ;
    skos:inScheme "https://w3id.org/nfosi/"^^xsd:anyURI ;
    skos:prefLabel "specimenID" ;
    linkml:definition_uri "https://w3id.org/synapse/nfosi/vocab/specimenID"^^xsd:anyURI ;
    linkml:description """A unique identifier (non-PII) that represents the subspecimen (subsample) from which the data came,  e.g. an ID that distinguishes between different parts of the same parent tumor specimen.
""" ;
    linkml:domain <https://w3id.org/synapse/nfosi/vocab/GeneticsAssayTemplate> ;
    linkml:domain_of <https://w3id.org/synapse/nfosi/vocab/GeneticsAssayTemplate> ;
    linkml:is_a <https://w3id.org/synapse/nfosi/vocab/specimenID> ;
    linkml:is_usage_slot true ;
    linkml:owner <https://w3id.org/synapse/nfosi/vocab/GeneticsAssayTemplate> ;
    linkml:range <https://w3id.org/synapse/nfosi/vocab/string> ;
    linkml:required true ;
    linkml:slot_uri "https://w3id.org/synapse/nfosi/vocab/specimenID"^^xsd:anyURI ;
    linkml:usage_slot_name "specimenID" .

<https://w3id.org/synapse/nfosi/vocab/GeneticsAssayTemplate_specimenPreparationMethod> a linkml:SlotDefinition ;
    dcterms:title "Specimen Preparation Method" ;
    skos:inScheme "https://w3id.org/nfosi/"^^xsd:anyURI ;
    skos:prefLabel "specimenPreparationMethod" ;
    linkml:definition_uri "https://w3id.org/synapse/nfosi/vocab/specimenPreparationMethod"^^xsd:anyURI ;
    linkml:description "Term that represents preservation of the sample before usage in, e.g. sequencing" ;
    linkml:domain <https://w3id.org/synapse/nfosi/vocab/GeneticsAssayTemplate> ;
    linkml:domain_of <https://w3id.org/synapse/nfosi/vocab/GeneticsAssayTemplate> ;
    linkml:is_a <https://w3id.org/synapse/nfosi/vocab/specimenPreparationMethod> ;
    linkml:is_usage_slot true ;
    linkml:owner <https://w3id.org/synapse/nfosi/vocab/GeneticsAssayTemplate> ;
    linkml:range <https://w3id.org/synapse/nfosi/vocab/SpecimenPreparationMethodEnum> ;
    linkml:required true ;
    linkml:slot_uri "https://w3id.org/synapse/nfosi/vocab/specimenPreparationMethod"^^xsd:anyURI ;
    linkml:usage_slot_name "specimenPreparationMethod" .

<https://w3id.org/synapse/nfosi/vocab/LightScatteringAssayTemplate> a linkml:ClassDefinition ;
    dcterms:source "https://wiki.nci.nih.gov/display/icr/isa-tab-nano"^^xsd:anyURI ;
    skos:inScheme "https://w3id.org/nfosi/"^^xsd:anyURI ;
    sh:rule [ a linkml:ClassRule ;
            sh:condition [ a linkml:AnonymousClassExpression ;
                    linkml:slot_conditions <https://w3id.org/synapse/nfosi/vocab/concentrationNaCl> ] ;
            linkml:description "If concentrationNaCl is provided, concentrationNaClUnit must be provided" ;
            linkml:postconditions [ a linkml:AnonymousClassExpression ;
                    linkml:slot_conditions <https://w3id.org/synapse/nfosi/vocab/concentrationNaClUnit> ] ] ;
    linkml:class_uri "https://w3id.org/synapse/nfosi/vocab/LightScatteringAssayTemplate"^^xsd:anyURI ;
    linkml:definition_uri "https://w3id.org/synapse/nfosi/vocab/LightScatteringAssayTemplate"^^xsd:anyURI ;
    linkml:description "Template for dynamic or static light scattering data adapted from ISA-TAB-Nano specs." ;
    linkml:is_a <https://w3id.org/synapse/nfosi/vocab/MaterialScienceAssayTemplate> ;
    linkml:slot_usage [ ] ;
    linkml:slots <https://w3id.org/synapse/nfosi/vocab/Component>,
        <https://w3id.org/synapse/nfosi/vocab/Filename>,
        <https://w3id.org/synapse/nfosi/vocab/LightScatteringAssayTemplate_assay>,
        <https://w3id.org/synapse/nfosi/vocab/LightScatteringAssayTemplate_fileFormat>,
        <https://w3id.org/synapse/nfosi/vocab/LightScatteringAssayTemplate_platform>,
        <https://w3id.org/synapse/nfosi/vocab/MaterialScienceAssayTemplate_specimenID>,
        <https://w3id.org/synapse/nfosi/vocab/NonBiologicalAssayDataTemplate_dataSubtype>,
        <https://w3id.org/synapse/nfosi/vocab/NonBiologicalAssayDataTemplate_dataType>,
        <https://w3id.org/synapse/nfosi/vocab/concentrationMaterial>,
        <https://w3id.org/synapse/nfosi/vocab/concentrationMaterialUnit>,
        <https://w3id.org/synapse/nfosi/vocab/concentrationNaCl>,
        <https://w3id.org/synapse/nfosi/vocab/concentrationNaClUnit>,
        <https://w3id.org/synapse/nfosi/vocab/materialType>,
        <https://w3id.org/synapse/nfosi/vocab/pH>,
        <https://w3id.org/synapse/nfosi/vocab/resourceType> .

<https://w3id.org/synapse/nfosi/vocab/ProcessedMergedDataTemplate> a linkml:ClassDefinition ;
    skos:closeMatch "https://docs.gdc.cancer.gov/Data_Dictionary/viewer/#?view=table-definition-view&id=aggregated_somatic_mutation"^^xsd:anyURI,
        "https://docs.gdc.cancer.gov/Data_Dictionary/viewer/#?view=table-definition-view&id=gene_expression"^^xsd:anyURI ;
    skos:inScheme "https://w3id.org/nfosi/"^^xsd:anyURI ;
    sh:rule [ a linkml:ClassRule ;
            sh:condition [ a linkml:AnonymousClassExpression ;
                    linkml:slot_conditions <https://w3id.org/synapse/nfosi/vocab/workflow> ] ;
            linkml:description "If workflow is provided, workflowLink must be provided" ;
            linkml:postconditions [ a linkml:AnonymousClassExpression ;
                    linkml:slot_conditions <https://w3id.org/synapse/nfosi/vocab/workflowLink> ] ],
        [ a linkml:ClassRule ;
            sh:condition [ a linkml:AnonymousClassExpression ;
                    linkml:slot_conditions <https://w3id.org/synapse/nfosi/vocab/resourceType> ] ;
            linkml:description "Relaxed conditional validation (issue #825): the listed fields are required only for experimentalData. Auxiliary co-located files (manifest, metadata, report, workflow report, tool, result, weblink, protocol) are exempt." ;
            linkml:postconditions [ a linkml:AnonymousClassExpression ;
                    linkml:slot_conditions <https://w3id.org/synapse/nfosi/vocab/assay>,
                        <https://w3id.org/synapse/nfosi/vocab/dataSubtype>,
                        <https://w3id.org/synapse/nfosi/vocab/dataType> ] ] ;
    linkml:class_uri "https://w3id.org/synapse/nfosi/vocab/ProcessedMergedDataTemplate"^^xsd:anyURI ;
    linkml:definition_uri "https://w3id.org/synapse/nfosi/vocab/ProcessedMergedDataTemplate"^^xsd:anyURI ;
    linkml:description """Further processed data with multiple samples aggregated into one file. This may be also be known as level-4 data. Unlike level-2 and level-3 data, individual-level attributes such as age and sex are no longer surfaced on the data file directly.
""" ;
    linkml:is_a <https://w3id.org/synapse/nfosi/vocab/FileBasedTemplate> ;
    linkml:slot_usage [ ] ;
    linkml:slots <https://w3id.org/synapse/nfosi/vocab/Component>,
        <https://w3id.org/synapse/nfosi/vocab/Filename>,
        <https://w3id.org/synapse/nfosi/vocab/ProcessedMergedDataTemplate_assay>,
        <https://w3id.org/synapse/nfosi/vocab/ProcessedMergedDataTemplate_dataSubtype>,
        <https://w3id.org/synapse/nfosi/vocab/ProcessedMergedDataTemplate_dataType>,
        <https://w3id.org/synapse/nfosi/vocab/auxiliaryAsset>,
        <https://w3id.org/synapse/nfosi/vocab/fileFormat>,
        <https://w3id.org/synapse/nfosi/vocab/resourceType>,
        <https://w3id.org/synapse/nfosi/vocab/workflow>,
        <https://w3id.org/synapse/nfosi/vocab/workflowLink> .

<https://w3id.org/synapse/nfosi/vocab/ProcessedVariantCallsTemplate> a linkml:ClassDefinition ;
    skos:closeMatch "htan:BulkWESLevel3"^^xsd:anyURI ;
    skos:inScheme "https://w3id.org/nfosi/"^^xsd:anyURI ;
    sh:rule [ a linkml:ClassRule ;
            sh:condition [ a linkml:AnonymousClassExpression ;
                    linkml:slot_conditions <https://w3id.org/synapse/nfosi/vocab/resourceType> ] ;
            linkml:description "Relaxed conditional validation (issue #825): the listed fields are required only for experimentalData. Auxiliary co-located files (manifest, metadata, report, workflow report, tool, result, weblink, protocol) are exempt." ;
            linkml:postconditions [ a linkml:AnonymousClassExpression ;
                    linkml:slot_conditions <https://w3id.org/synapse/nfosi/vocab/specimenID> ] ],
        [ a linkml:ClassRule ;
            sh:condition [ a linkml:AnonymousClassExpression ;
                    linkml:slot_conditions <https://w3id.org/synapse/nfosi/vocab/workflow> ] ;
            linkml:description "If workflow is provided, workflowLink must be provided" ;
            linkml:postconditions [ a linkml:AnonymousClassExpression ;
                    linkml:slot_conditions <https://w3id.org/synapse/nfosi/vocab/workflowLink> ] ] ;
    linkml:class_uri "https://w3id.org/synapse/nfosi/vocab/ProcessedVariantCallsTemplate"^^xsd:anyURI ;
    linkml:definition_uri "https://w3id.org/synapse/nfosi/vocab/ProcessedVariantCallsTemplate"^^xsd:anyURI ;
    linkml:description "Template for describing either simple germline/somatic variant calls output data (VCF/MAF) as well as structural variants (e.g. CNVs)." ;
    linkml:is_a <https://w3id.org/synapse/nfosi/vocab/BiologicalAssayDataTemplate> ;
    linkml:slot_usage [ ] ;
    linkml:slots <https://w3id.org/synapse/nfosi/vocab/BiologicalAssayDataTemplate_assay>,
        <https://w3id.org/synapse/nfosi/vocab/BiologicalAssayDataTemplate_dataType>,
        <https://w3id.org/synapse/nfosi/vocab/BiologicalAssayDataTemplate_diagnosis>,
