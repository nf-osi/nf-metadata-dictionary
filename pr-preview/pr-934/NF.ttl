<https://w3id.org/synapse/nfosi/vocab/doi> a linkml:SlotDefinition ;
    dcterms:title "DOI",
        "Digital Object Identifier",
        "doi" ;
    skos:inScheme "https://w3id.org/nfosi/"^^xsd:anyURI ;
    linkml:definition_uri "https://w3id.org/synapse/nfosi/vocab/doi"^^xsd:anyURI ;
    linkml:description "Digital object identifier of the resource.",
        "The Digital Object Identifier (DOI) of the dataset (if one has been created), used for citation and persistent identification." ;
    linkml:pattern "^10\\\\.\\\\d{4,9}/[-._;()/:A-Z0-9]+$" ;
    linkml:range <https://w3id.org/synapse/nfosi/vocab/string> ;
    linkml:required true ;
    linkml:slot_uri "https://w3id.org/synapse/nfosi/vocab/doi"^^xsd:anyURI .

