    linkml:meaning "NCIT:C184775"^^xsd:anyURI .

<https://w3id.org/synapse/nfosi/vocab/mass%20spectrometry> linkml:description "A generic mass spectrometry assay that allows identification and amount of peptide or protein materials." ;
