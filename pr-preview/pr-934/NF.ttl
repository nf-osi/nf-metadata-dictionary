    linkml:meaning "NCIT:C12745"^^xsd:anyURI .

<https://w3id.org/synapse/nfosi/vocab/lymphoblast> linkml:description "Often referred to as a blast cell. Unlike other usages of the suffix -blast a lymphoblast is a further differentiation of a lymphocyte, T- or B-, occasioned by an antigenic stimulus. The lymphoblast usually develops by enlargement of a lymphocyte, active re-entry to the S phase of the cell cycle, mitogenesis and production of much m-RNA and ribosomes." ;
    linkml:meaning "BTO:0000772"^^xsd:anyURI .

<https://w3id.org/synapse/nfosi/vocab/mM> linkml:description "" .

<https://w3id.org/synapse/nfosi/vocab/mTOR%20inhibitor> linkml:meaning "NCIT:C2201"^^xsd:anyURI .

<https://w3id.org/synapse/nfosi/vocab/macrophages> skos:altLabel "histiocyte" ;
    linkml:description "A mononuclear phagocyte present in variety of tissues, typically differentiated from monocytes, capable of phagocytosing a variety of extracellular particulate material, including immune complexes, microorganisms, and dead cells." ;
    linkml:meaning "CL:0000235"^^xsd:anyURI .

<https://w3id.org/synapse/nfosi/vocab/maf> dcterms:source "https://docs.gdc.cancer.gov/Data/File_Formats/MAF_Format"^^xsd:anyURI ;
    skos:editorialNote "DO NOT use http://edamontology.org/format_3008 as that refers to Multiple Alignment Format (MAF)." ;
