    linkml:description "A specialized accessory gland of the skin of mammals that secretes milk. The gland is typically only developed in females, and regresses in males." ;
    linkml:meaning "UBERON:0001911"^^xsd:anyURI .

<https://w3id.org/synapse/nfosi/vocab/manifest> linkml:description "A metadata manifest file used for validation and annotation of other data files. Different validation rules may apply to manifests compared to experimental data files." .

<https://w3id.org/synapse/nfosi/vocab/mask%20image> linkml:description "Image used as the mask for an image processing operation, such as subtraction." ;
    linkml:meaning "DCM:121321"^^xsd:anyURI .

