<https://w3id.org/synapse/nfosi/vocab/age> a linkml:SlotDefinition ;
    dcterms:title "Age" ;
    skos:inScheme "https://w3id.org/nfosi/"^^xsd:anyURI ;
    linkml:any_of [ a linkml:AnonymousSlotExpression ;
            linkml:range <https://w3id.org/synapse/nfosi/vocab/AgeMask> ],
        [ a linkml:AnonymousSlotExpression ;
            linkml:range <https://w3id.org/synapse/nfosi/vocab/float> ] ;
    linkml:definition_uri "https://w3id.org/synapse/nfosi/vocab/age"^^xsd:anyURI ;
    linkml:description "Age of the individual. Use with `ageUnit`. IMPORTANT: For human data, HIPAA requires masking ages >= 90; use the `AgeMask` value \">= 90\" instead of the exact value to protect participant privacy." ;
    linkml:domain_of <https://w3id.org/synapse/nfosi/vocab/AnimalIndividualTemplate>,
        <https://w3id.org/synapse/nfosi/vocab/BiologicalAssayDataTemplate>,
        <https://w3id.org/synapse/nfosi/vocab/HumanCohortTemplate> ;
    linkml:maximum_value "89.99999"^^<https://w3id.org/linkml/@id> ;
    linkml:none_of [ a linkml:AnonymousSlotExpression ;
            linkml:equals_string "Unknown" ],
        [ a linkml:AnonymousSlotExpression ;
            linkml:equals_string "Unknown" ] ;
    linkml:owner <https://w3id.org/synapse/nfosi/vocab/BiologicalAssayDataTemplate> ;
    linkml:range <https://w3id.org/synapse/nfosi/vocab/string> ;
    linkml:slot_uri "https://w3id.org/synapse/nfosi/vocab/age"^^xsd:anyURI ;
    linkml:value_presence [ a linkml:PermissibleValue ;
            skos:notation "PRESENT" ],
        [ a linkml:PermissibleValue ;
            skos:notation "PRESENT" ] .

