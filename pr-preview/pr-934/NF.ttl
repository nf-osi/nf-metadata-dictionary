    skos:inScheme "https://w3id.org/nfosi/"^^xsd:anyURI ;
    linkml:definition_uri "https://w3id.org/synapse/nfosi/vocab/aliquotID"^^xsd:anyURI ;
    linkml:description "A unique identifier (non-PII) that represents the aliquots used for e.g. replicate runs. This is linked to the specimenID." ;
