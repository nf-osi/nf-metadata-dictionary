<https://w3id.org/synapse/nfosi/vocab/portalDataset__measurementTechnique> a linkml:SlotDefinition ;
    dcterms:title "Measurement Technique" ;
    skos:inScheme "https://w3id.org/nfosi/"^^xsd:anyURI ;
    skos:prefLabel "measurementTechnique" ;
    linkml:any_of [ a linkml:AnonymousSlotExpression ;
            linkml:range <https://w3id.org/synapse/nfosi/vocab/CellBasedAssayEnum> ],
        [ a linkml:AnonymousSlotExpression ;
            linkml:range <https://w3id.org/synapse/nfosi/vocab/MassSpectrometryAssayEnum> ],
        [ a linkml:AnonymousSlotExpression ;
            linkml:range <https://w3id.org/synapse/nfosi/vocab/ImagingAssayEnum> ],
        [ a linkml:AnonymousSlotExpression ;
            linkml:range <https://w3id.org/synapse/nfosi/vocab/ClinicalBehavioralAssayEnum> ],
        [ a linkml:AnonymousSlotExpression ;
            linkml:range <https://w3id.org/synapse/nfosi/vocab/SequencingAssayEnum> ],
        [ a linkml:AnonymousSlotExpression ;
            linkml:range <https://w3id.org/synapse/nfosi/vocab/DrugScreenAssayEnum> ] ;
    linkml:description "Method used to generate data in dataset, typically referring to the assay. Omit if not applicable (e.g. for curated dataset such as a list compounds from a database or text extracted from Wikipedia)." ;
    linkml:domain_of <https://w3id.org/synapse/nfosi/vocab/PortalDataset> ;
    linkml:multivalued true ;
    linkml:owner <https://w3id.org/synapse/nfosi/vocab/PortalDataset> ;
    linkml:range <https://w3id.org/synapse/nfosi/vocab/string> ;
    linkml:slot_uri "https://w3id.org/synapse/nfosi/vocab/measurementTechnique"^^xsd:anyURI .

