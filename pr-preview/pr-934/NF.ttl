<https://w3id.org/synapse/nfosi/vocab/experimentalFactor> a linkml:SlotDefinition ;
    dcterms:title "Experimental Factor" ;
    skos:editorialNote "Note that this enforces a concept term from EFO (currently preferred), while the related `experimentalCondition` is free-text and much more specific." ;
