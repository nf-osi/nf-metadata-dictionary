<https://w3id.org/synapse/nfosi/vocab/Attune%20Flow%20Cytometer> dcterms:source "https://www.thermofisher.com/us/en/home/life-science/cell-analysis/flow-cytometry/flow-cytometers/attune-nxt-flow-cytometer.html"^^xsd:anyURI ;
