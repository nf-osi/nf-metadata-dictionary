    linkml:required true ;
    linkml:slot_uri "https://w3id.org/synapse/nfosi/vocab/species"^^xsd:anyURI ;
    linkml:usage_slot_name "species" .

<https://w3id.org/synapse/nfosi/vocab/antibodyID> a linkml:SlotDefinition ;
    skos:inScheme "https://w3id.org/nfosi/"^^xsd:anyURI ;
    linkml:any_of [ a linkml:AnonymousSlotExpression ;
            linkml:range <https://w3id.org/synapse/nfosi/vocab/string> ],
        [ a linkml:AnonymousSlotExpression ;
            linkml:range <https://w3id.org/synapse/nfosi/vocab/AntibodyEnum> ] ;
    linkml:definition_uri "https://w3id.org/synapse/nfosi/vocab/antibodyID"^^xsd:anyURI ;
    linkml:description "Antibody identifier. Select from the controlled vocabulary of antibodies in NF Research Tools Central (syn51730943) when available, or provide a custom identifier. Links to antibody details are available in the schema see_also field for enum values." ;
    linkml:domain_of <https://w3id.org/synapse/nfosi/vocab/AffinityProteomicsTemplate>,
        <https://w3id.org/synapse/nfosi/vocab/BiologicalAssayDataTemplate>,
        <https://w3id.org/synapse/nfosi/vocab/ChIPSeqTemplate>,
        <https://w3id.org/synapse/nfosi/vocab/MicroscopyAssayTemplate> ;
    linkml:owner <https://w3id.org/synapse/nfosi/vocab/AffinityProteomicsTemplate> ;
    linkml:range <https://w3id.org/synapse/nfosi/vocab/string> ;
    linkml:slot_uri "https://w3id.org/synapse/nfosi/vocab/antibodyID"^^xsd:anyURI .

<https://w3id.org/synapse/nfosi/vocab/geneticReagentID> a linkml:SlotDefinition ;
    skos:inScheme "https://w3id.org/nfosi/"^^xsd:anyURI ;
    linkml:any_of [ a linkml:AnonymousSlotExpression ;
            linkml:range <https://w3id.org/synapse/nfosi/vocab/GeneticReagentEnum> ],
        [ a linkml:AnonymousSlotExpression ;
            linkml:range <https://w3id.org/synapse/nfosi/vocab/string> ] ;
    linkml:definition_uri "https://w3id.org/synapse/nfosi/vocab/geneticReagentID"^^xsd:anyURI ;
    linkml:description "Identifier for genetic reagent used (e.g., CRISPR construct, shRNA, plasmid). Select from the controlled vocabulary of genetic reagents in NF Research Tools Central (syn51730943) when available, or provide a custom identifier. Links to reagent details are available in the schema see_also field for enum values." ;
    linkml:domain_of <https://w3id.org/synapse/nfosi/vocab/BiologicalAssayDataTemplate> ;
    linkml:owner <https://w3id.org/synapse/nfosi/vocab/BiologicalAssayDataTemplate> ;
    linkml:range <https://w3id.org/synapse/nfosi/vocab/string> ;
    linkml:slot_uri "https://w3id.org/synapse/nfosi/vocab/geneticReagentID"^^xsd:anyURI .

<https://w3id.org/synapse/nfosi/vocab/organ> a linkml:SlotDefinition ;
    dcterms:title "Organ" ;
    skos:inScheme "https://w3id.org/nfosi/"^^xsd:anyURI ;
    linkml:definition_uri "https://w3id.org/synapse/nfosi/vocab/organ"^^xsd:anyURI ;
    linkml:description "A unique macroscopic (gross) anatomic structure that performs specific functions. It is composed of various tissues. An organ is part of an anatomic system or a body region." ;
    linkml:domain_of <https://w3id.org/synapse/nfosi/vocab/BiologicalAssayDataTemplate> ;
    linkml:owner <https://w3id.org/synapse/nfosi/vocab/BiologicalAssayDataTemplate> ;
    linkml:range <https://w3id.org/synapse/nfosi/vocab/OrganEnum> ;
    linkml:slot_uri "https://w3id.org/synapse/nfosi/vocab/organ"^^xsd:anyURI ;
    linkml:value_presence [ a linkml:PermissibleValue ;
            skos:notation "PRESENT" ] .

<https://w3id.org/synapse/nfosi/vocab/nf1Genotype> a linkml:SlotDefinition ;
    dcterms:title "NF1 Genotype" ;
    rdfs:seeAlso "nf1Variant"^^xsd:anyURI,
        "nf2Genotype"^^xsd:anyURI ;
    skos:inScheme "https://w3id.org/nfosi/"^^xsd:anyURI ;
    linkml:any_of [ a linkml:AnonymousSlotExpression ;
