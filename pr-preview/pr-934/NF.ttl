<https://w3id.org/synapse/nfosi/vocab/BiologicalAssayDataTemplate> a linkml:ClassDefinition ;
    skos:inScheme "https://w3id.org/nfosi/"^^xsd:anyURI ;
    sh:rule [ a linkml:ClassRule ;
            sh:condition [ a linkml:AnonymousClassExpression ;
                    linkml:slot_conditions <https://w3id.org/synapse/nfosi/vocab/species> ] ;
            linkml:description "For Homo sapiens, age must be < 90; use the \">= 90\" AgeMask value for ages at or above this threshold (HIPAA Safe Harbor)" ;
            linkml:postconditions [ a linkml:AnonymousClassExpression ;
                    linkml:slot_conditions <https://w3id.org/synapse/nfosi/vocab/age> ] ],
        [ a linkml:ClassRule ;
            sh:condition [ a linkml:AnonymousClassExpression ;
                    linkml:slot_conditions <https://w3id.org/synapse/nfosi/vocab/age> ] ;
            linkml:description "If age is provided and is not \"Unknown\", ageUnit must be provided" ;
            linkml:postconditions [ a linkml:AnonymousClassExpression ;
                    linkml:slot_conditions <https://w3id.org/synapse/nfosi/vocab/ageUnit> ] ],
        [ a linkml:ClassRule ;
            sh:condition [ a linkml:AnonymousClassExpression ;
                    linkml:slot_conditions <https://w3id.org/synapse/nfosi/vocab/dataType> ] ;
            linkml:description "If dataType is provided, dataSubtype must be provided" ;
            linkml:postconditions [ a linkml:AnonymousClassExpression ;
                    linkml:slot_conditions <https://w3id.org/synapse/nfosi/vocab/dataSubtype> ] ],
        [ a linkml:ClassRule ;
            sh:condition [ a linkml:AnonymousClassExpression ;
                    linkml:slot_conditions <https://w3id.org/synapse/nfosi/vocab/resourceType> ] ;
            linkml:description "Relaxed conditional validation (issue #825): the listed fields are required only for experimentalData. Auxiliary co-located files (manifest, metadata, report, workflow report, tool, result, weblink, protocol) are exempt." ;
            linkml:postconditions [ a linkml:AnonymousClassExpression ;
                    linkml:slot_conditions <https://w3id.org/synapse/nfosi/vocab/assay>,
                        <https://w3id.org/synapse/nfosi/vocab/dataSubtype>,
                        <https://w3id.org/synapse/nfosi/vocab/dataType>,
                        <https://w3id.org/synapse/nfosi/vocab/diagnosis>,
                        <https://w3id.org/synapse/nfosi/vocab/individualID>,
                        <https://w3id.org/synapse/nfosi/vocab/species>,
                        <https://w3id.org/synapse/nfosi/vocab/tumorType> ] ] ;
    linkml:abstract true ;
    linkml:class_uri "https://w3id.org/synapse/nfosi/vocab/BiologicalAssayDataTemplate"^^xsd:anyURI ;
    linkml:definition_uri "https://w3id.org/synapse/nfosi/vocab/BiologicalAssayDataTemplate"^^xsd:anyURI ;
    linkml:description "A template defining basic metadata on deposited data artifacts (i.e. files) from experimental assays involving biosamples. Donor/individual attributes (species, sex, age, diagnosis) describe the original donor (e.g., human patient tumor). For cell lines, individualID references syn51730943. antibodyID and geneticReagentID reference treatments/reagents. For PDX data, use PdxGenomicsAssayTemplate which includes model* attributes." ;
    linkml:is_a <https://w3id.org/synapse/nfosi/vocab/FileBasedTemplate> ;
    linkml:slot_usage [ ] ;
    linkml:slots <https://w3id.org/synapse/nfosi/vocab/BiologicalAssayDataTemplate_assay>,
        <https://w3id.org/synapse/nfosi/vocab/BiologicalAssayDataTemplate_dataSubtype>,
        <https://w3id.org/synapse/nfosi/vocab/BiologicalAssayDataTemplate_dataType>,
        <https://w3id.org/synapse/nfosi/vocab/BiologicalAssayDataTemplate_diagnosis>,
        <https://w3id.org/synapse/nfosi/vocab/BiologicalAssayDataTemplate_individualID>,
        <https://w3id.org/synapse/nfosi/vocab/BiologicalAssayDataTemplate_species>,
        <https://w3id.org/synapse/nfosi/vocab/BiologicalAssayDataTemplate_tumorType>,
        <https://w3id.org/synapse/nfosi/vocab/Component>,
        <https://w3id.org/synapse/nfosi/vocab/Filename>,
        <https://w3id.org/synapse/nfosi/vocab/age>,
        <https://w3id.org/synapse/nfosi/vocab/ageUnit>,
        <https://w3id.org/synapse/nfosi/vocab/antibodyID>,
        <https://w3id.org/synapse/nfosi/vocab/comments>,
        <https://w3id.org/synapse/nfosi/vocab/fileFormat>,
        <https://w3id.org/synapse/nfosi/vocab/geneticReagentID>,
        <https://w3id.org/synapse/nfosi/vocab/nf1Genotype>,
        <https://w3id.org/synapse/nfosi/vocab/nf2Genotype>,
        <https://w3id.org/synapse/nfosi/vocab/organ>,
        <https://w3id.org/synapse/nfosi/vocab/resourceType>,
        <https://w3id.org/synapse/nfosi/vocab/sex> .

<https://w3id.org/synapse/nfosi/vocab/PortalDataset> a linkml:ClassDefinition ;
    skos:editorialNote "The compiled JSON schema for this should be bound to [Dataset](https://rest-docs.synapse.org/rest/org/sagebionetworks/repo/model/table/Dataset.html) entities, not folders.",
        "While \"publisher\" (repository) may seem redundant given that all Datasets are obviously on Synapse, it's for explicit compatibility with DataCite, and eventually may want to have \"symbolic\" datasets like Cancer Complexity Portal that list datasets hosted somewhere else." ;
    skos:inScheme "https://w3id.org/nfosi/"^^xsd:anyURI ;
    linkml:attributes <https://w3id.org/synapse/nfosi/vocab/accessType>,
        <https://w3id.org/synapse/nfosi/vocab/ageGroup>,
