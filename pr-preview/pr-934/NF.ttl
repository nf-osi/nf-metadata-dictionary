    linkml:slot_usage [ ] ;
    linkml:slots <https://w3id.org/synapse/nfosi/vocab/Component>,
        <https://w3id.org/synapse/nfosi/vocab/EpidemiologyDataTemplate_dataType>,
        <https://w3id.org/synapse/nfosi/vocab/EpidemiologyDataTemplate_epidemiologyMetric>,
