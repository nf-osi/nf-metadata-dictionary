<https://w3id.org/synapse/nfosi/vocab/ProcessedAggregatedDataTemplate> a linkml:ClassDefinition ;
    skos:inScheme "https://w3id.org/nfosi/"^^xsd:anyURI ;
    sh:rule [ a linkml:ClassRule ;
            sh:condition [ a linkml:AnonymousClassExpression ;
                    linkml:slot_conditions <https://w3id.org/synapse/nfosi/vocab/workflow> ] ;
            linkml:description "If workflow is provided, workflowLink must be provided" ;
            linkml:postconditions [ a linkml:AnonymousClassExpression ;
                    linkml:slot_conditions <https://w3id.org/synapse/nfosi/vocab/workflowLink> ] ],
        [ a linkml:ClassRule ;
            sh:condition [ a linkml:AnonymousClassExpression ;
                    linkml:slot_conditions <https://w3id.org/synapse/nfosi/vocab/resourceType> ] ;
            linkml:description "Relaxed conditional validation (issue #825): the listed fields are required only for experimentalData. Auxiliary co-located files (manifest, metadata, report, workflow report, tool, result, weblink, protocol) are exempt." ;
            linkml:postconditions [ a linkml:AnonymousClassExpression ;
                    linkml:slot_conditions <https://w3id.org/synapse/nfosi/vocab/assay>,
                        <https://w3id.org/synapse/nfosi/vocab/dataSubtype>,
                        <https://w3id.org/synapse/nfosi/vocab/dataType> ] ] ;
    linkml:class_uri "https://w3id.org/synapse/nfosi/vocab/ProcessedAggregatedDataTemplate"^^xsd:anyURI ;
    linkml:definition_uri "https://w3id.org/synapse/nfosi/vocab/ProcessedAggregatedDataTemplate"^^xsd:anyURI ;
    linkml:description "Template for processed data aggregated across multiple specimens into a single file, where individual-level attributes (specimenID, individualID) do not apply. Use for summarized assay results such as qPCR Ct value tables." ;
    linkml:is_a <https://w3id.org/synapse/nfosi/vocab/FileBasedTemplate> ;
    linkml:slot_usage [ ] ;
    linkml:slots <https://w3id.org/synapse/nfosi/vocab/Component>,
        <https://w3id.org/synapse/nfosi/vocab/Filename>,
        <https://w3id.org/synapse/nfosi/vocab/ProcessedAggregatedDataTemplate_assay>,
        <https://w3id.org/synapse/nfosi/vocab/ProcessedAggregatedDataTemplate_dataSubtype>,
        <https://w3id.org/synapse/nfosi/vocab/ProcessedAggregatedDataTemplate_dataType>,
