<https://w3id.org/synapse/nfosi/vocab/enzymatic> dcterms:source "https://github.com/HumanCellAtlas/metadata-schema/blob/master/json_schema/type/process/sequencing/library_preparation_process.json"^^xsd:anyURI ;
