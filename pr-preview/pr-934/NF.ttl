<https://w3id.org/synapse/nfosi/vocab/delta-ira1%20delta-ira2%20yeast> dcterms:source "https://nf.synapse.org/Explore/Tools/DetailsPage/Details?resourceId=9b2a7ee1-e462-42b9-80b8-0a64ca60b091"^^xsd:anyURI ;
