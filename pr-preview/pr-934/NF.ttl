    linkml:description "One of the usually paired compound saccular thoracic organs that constitute the basic respiratory organ of air-breathing vertebrates." ;
    linkml:meaning "BTO:0000763"^^xsd:anyURI .

<https://w3id.org/synapse/nfosi/vocab/lymph%20node> skos:altLabel "Lymph Gland",
