<https://w3id.org/synapse/nfosi/vocab/BiologicalAssayDataTemplate_individualID> a linkml:SlotDefinition ;
    dcterms:title "Individual ID" ;
    skos:inScheme "https://w3id.org/nfosi/"^^xsd:anyURI ;
    skos:prefLabel "individualID" ;
    linkml:definition_uri "https://w3id.org/synapse/nfosi/vocab/individualID"^^xsd:anyURI ;
    linkml:description "A unique identifier (non-PII) that represents the individual from which the data came. This could be a patient or animal ID." ;
