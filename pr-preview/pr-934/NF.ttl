    linkml:description "The statistical characterization of human populations or segments of human populations (e.g., characterization by age, sex, race, or income)." ;
    linkml:meaning "NCIT:C16495"^^xsd:anyURI .

<https://w3id.org/synapse/nfosi/vocab/derived> linkml:description "Data from additional analytical steps performed on already processed data." .

<https://w3id.org/synapse/nfosi/vocab/descriptive%20metadata> skos:editorialNote "Currently used for `manifest.csv` files." ;
