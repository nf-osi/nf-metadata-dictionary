<https://w3id.org/synapse/nfosi/vocab/resourceType> a linkml:SlotDefinition ;
    dcterms:title "Resource Type" ;
    skos:inScheme "https://w3id.org/nfosi/"^^xsd:anyURI ;
    linkml:definition_uri "https://w3id.org/synapse/nfosi/vocab/resourceType"^^xsd:anyURI ;
    linkml:description "The type of resource being stored and annotated" ;
    linkml:domain_of <https://w3id.org/synapse/nfosi/vocab/FileBasedTemplate>,
        <https://w3id.org/synapse/nfosi/vocab/ProtocolTemplate>,
        <https://w3id.org/synapse/nfosi/vocab/SourceCodeTemplate>,
        <https://w3id.org/synapse/nfosi/vocab/UpdateMilestoneReport> ;
    linkml:equals_string "experimentalData" ;
    linkml:owner <https://w3id.org/synapse/nfosi/vocab/SourceCodeTemplate> ;
