    linkml:definition_uri "https://w3id.org/synapse/nfosi/vocab/MicroscopyAssayTemplate"^^xsd:anyURI ;
    linkml:description "Template for microscopy imaging data. For immunofluorescence or immunohistochemistry assays, provide antibodyID." ;
