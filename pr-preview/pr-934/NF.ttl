    skos:inScheme "https://w3id.org/nfosi/"^^xsd:anyURI ;
    linkml:definition_uri "https://w3id.org/synapse/nfosi/vocab/cellID"^^xsd:anyURI ;
    linkml:description "Also known as cell barcode, this value can be added for single-cell experiments to identify data at the cell level." ;
    linkml:domain_of <https://w3id.org/synapse/nfosi/vocab/ScSequencingAssayTemplate> ;
    linkml:owner <https://w3id.org/synapse/nfosi/vocab/ScSequencingAssayTemplate> ;
    linkml:range <https://w3id.org/synapse/nfosi/vocab/string> ;
    linkml:slot_uri "https://w3id.org/synapse/nfosi/vocab/cellID"^^xsd:anyURI .

