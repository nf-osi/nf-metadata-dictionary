    linkml:slot_uri "https://w3id.org/synapse/nfosi/vocab/sex"^^xsd:anyURI .

<https://w3id.org/synapse/nfosi/vocab/TabularFileFormatEnum> dcterms:title "Tabular File Format" ;
    skos:inScheme "https://w3id.org/nfosi/"^^xsd:anyURI ;
    linkml:definition_uri "https://w3id.org/synapse/nfosi/vocab/TabularFileFormatEnum"^^xsd:anyURI ;
    linkml:description "Tabular data formats including spreadsheets and delimited files" ;
    linkml:permissible_values <https://w3id.org/synapse/nfosi/vocab/RCC>,
        <https://w3id.org/synapse/nfosi/vocab/csv>,
        <https://w3id.org/synapse/nfosi/vocab/excel>,
        <https://w3id.org/synapse/nfosi/vocab/parquet>,
        <https://w3id.org/synapse/nfosi/vocab/tsv>,
        <https://w3id.org/synapse/nfosi/vocab/txt> .

<https://w3id.org/synapse/nfosi/vocab/PlateBasedReporterAssayTemplate> a linkml:ClassDefinition ;
    skos:inScheme "https://w3id.org/nfosi/"^^xsd:anyURI ;
    sh:rule [ a linkml:ClassRule ;
            sh:condition [ a linkml:AnonymousClassExpression ;
                    linkml:slot_conditions <https://w3id.org/synapse/nfosi/vocab/compoundDose> ] ;
            linkml:description "If compoundDose is provided, compoundDoseUnit must be provided" ;
            linkml:postconditions [ a linkml:AnonymousClassExpression ;
                    linkml:slot_conditions <https://w3id.org/synapse/nfosi/vocab/compoundDoseUnit> ] ],
        [ a linkml:ClassRule ;
            sh:condition [ a linkml:AnonymousClassExpression ;
                    linkml:slot_conditions <https://w3id.org/synapse/nfosi/vocab/experimentalTimepoint> ] ;
            linkml:description "If experimentalTimepoint is provided, timepointUnit must be provided" ;
            linkml:postconditions [ a linkml:AnonymousClassExpression ;
                    linkml:slot_conditions <https://w3id.org/synapse/nfosi/vocab/timepointUnit> ] ],
        [ a linkml:ClassRule ;
            sh:condition [ a linkml:AnonymousClassExpression ;
                    linkml:slot_conditions <https://w3id.org/synapse/nfosi/vocab/resourceType> ] ;
            linkml:description "Relaxed conditional validation (issue #825): the listed fields are required only for experimentalData. Auxiliary co-located files (manifest, metadata, report, workflow report, tool, result, weblink, protocol) are exempt." ;
            linkml:postconditions [ a linkml:AnonymousClassExpression ;
                    linkml:slot_conditions <https://w3id.org/synapse/nfosi/vocab/compoundDose>,
                        <https://w3id.org/synapse/nfosi/vocab/compoundDoseUnit>,
                        <https://w3id.org/synapse/nfosi/vocab/compoundName>,
                        <https://w3id.org/synapse/nfosi/vocab/specimenID> ] ] ;
