    linkml:required true ;
    linkml:slot_uri "https://w3id.org/synapse/nfosi/vocab/resourceType"^^xsd:anyURI .

<https://w3id.org/synapse/nfosi/vocab/HumanCohortTemplate> a linkml:ClassDefinition ;
    skos:editorialNote "Include attributes used for the portal but not in recommendations (nf1Genotype, nf1Genotype, species).",
        "Instead of collecting birth month/year, age is collected.",
        "What has been required is still required, while all new recommendations are optional." ;
    skos:inScheme "https://w3id.org/nfosi/"^^xsd:anyURI ;
    sh:rule [ a linkml:ClassRule ;
            sh:condition [ a linkml:AnonymousClassExpression ;
                    linkml:slot_conditions <https://w3id.org/synapse/nfosi/vocab/age> ] ;
            linkml:description "If age is provided and is not \"Unknown\", ageUnit must be provided" ;
            linkml:postconditions [ a linkml:AnonymousClassExpression ;
                    linkml:slot_conditions <https://w3id.org/synapse/nfosi/vocab/ageUnit> ] ],
        [ a linkml:ClassRule ;
            sh:condition [ a linkml:AnonymousClassExpression ;
                    linkml:slot_conditions <https://w3id.org/synapse/nfosi/vocab/species> ] ;
            linkml:description "For Homo sapiens, age must be < 90; use the \">= 90\" AgeMask value for ages at or above this threshold (HIPAA Safe Harbor)" ;
            linkml:postconditions [ a linkml:AnonymousClassExpression ;
                    linkml:slot_conditions <https://w3id.org/synapse/nfosi/vocab/age> ] ] ;
    linkml:class_uri "https://w3id.org/synapse/nfosi/vocab/HumanCohortTemplate"^^xsd:anyURI ;
    linkml:definition_uri "https://w3id.org/synapse/nfosi/vocab/HumanCohortTemplate"^^xsd:anyURI ;
    linkml:description """Data of biosamples from human patients. Adapted from Table 2 of http://nrs.harvard.edu/urn-3:HUL.InstRepos:32725809. This template should be used when biosamples are from NF patients to provides a more valuable characterization and make additional gene-phenotype insights possible.
""" ;
    linkml:slot_usage [ ] ;
    linkml:slots <https://w3id.org/synapse/nfosi/vocab/GIST>,
        <https://w3id.org/synapse/nfosi/vocab/HumanCohortTemplate_species>,
