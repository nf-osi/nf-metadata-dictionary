<https://w3id.org/synapse/nfosi/vocab/BulkSequencingAssayTemplate_libraryStrand> a linkml:SlotDefinition ;
    dcterms:title "Library Strand" ;
    skos:editorialNote "Meaning originally captured with combination of readPairOrientation and readStrandOrigin.",
        "https://littlebitofdata.com/en/2017/08/strandness_in_rnaseq/" ;
