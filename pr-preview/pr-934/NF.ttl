    linkml:uri "http://www.w3.org/2001/XMLSchema#anyURI"^^xsd:anyURI .

<https://w3id.org/synapse/nfosi/vocab/vcf> linkml:description "Variant Call Format (VCF) for sequence variation (indels, polymorphisms, structural variation)" ;
    linkml:meaning "EDAM:format_3016"^^xsd:anyURI .

<https://w3id.org/synapse/nfosi/vocab/vectorBackbone> a linkml:SlotDefinition ;
