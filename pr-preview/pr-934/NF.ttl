<https://w3id.org/synapse/nfosi/vocab/batchID> a linkml:SlotDefinition ;
    dcterms:title "Batch ID" ;
    skos:inScheme "https://w3id.org/nfosi/"^^xsd:anyURI ;
    linkml:definition_uri "https://w3id.org/synapse/nfosi/vocab/batchID"^^xsd:anyURI ;
    linkml:description "Batch identifier, can be used in any context where added batch information is helpful, such as different sequencing runs or collection times." ;
