<https://w3id.org/synapse/nfosi/vocab/bisulfiteConversionKitID> a linkml:SlotDefinition ;
    dcterms:title "Bisulfite Conversion Kit ID" ;
    skos:inScheme "https://w3id.org/nfosi/"^^xsd:anyURI ;
    linkml:definition_uri "https://w3id.org/synapse/nfosi/vocab/bisulfiteConversionKitID"^^xsd:anyURI ;
    linkml:description "Name of kit used in bisulfite conversion." ;
    linkml:domain_of <https://w3id.org/synapse/nfosi/vocab/EpigenomicsAssayTemplate> ;
    linkml:owner <https://w3id.org/synapse/nfosi/vocab/EpigenomicsAssayTemplate> ;
    linkml:range <https://w3id.org/synapse/nfosi/vocab/string> ;
    linkml:slot_uri "https://w3id.org/synapse/nfosi/vocab/bisulfiteConversionKitID"^^xsd:anyURI .

<https://w3id.org/synapse/nfosi/vocab/captureArea> a linkml:SlotDefinition ;
    dcterms:title "Capture Area" ;
    skos:inScheme "https://w3id.org/nfosi/"^^xsd:anyURI ;
    linkml:definition_uri "https://w3id.org/synapse/nfosi/vocab/captureArea"^^xsd:anyURI ;
    linkml:description """One of the either four or two active regions where tissue can be placed on a Visium slide. Each area is intended to contain only one tissue sample.  Slide areas are named consecutively from top to bottom:  A1, B1, C1, D1 for Visium slides with 6.5 mm Capture Area and A, B for CytAssist slides with 11 mm Capture Area.  Both CytAssist slides with 6.5 mm Capture Area and Gateway Slides contain only two slide areas, A1 and D1.
""" ;
    linkml:domain_of <https://w3id.org/synapse/nfosi/vocab/SpatialTranscriptomicsImagingTemplate>,
        <https://w3id.org/synapse/nfosi/vocab/SpatialTranscriptomicsSequencingTemplate> ;
    linkml:owner <https://w3id.org/synapse/nfosi/vocab/SpatialTranscriptomicsImagingTemplate> ;
    linkml:range <https://w3id.org/synapse/nfosi/vocab/string> ;
    linkml:slot_uri "https://w3id.org/synapse/nfosi/vocab/captureArea"^^xsd:anyURI .

<https://w3id.org/synapse/nfosi/vocab/cellID> a linkml:SlotDefinition ;
